<div class="welcome-sec">
    <h1>Visão Geral do Painel</h1>
    <p>Acompanhe o faturamento, controle de estoque e últimas operações da loja.</p>
</div>

{{#if storeDiagnostic}}
<div class="alert mt-3 mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2" style="background-color: var(--primary-light); border-left: 4px solid var(--primary); padding: 1rem 1.5rem; border-radius: 8px;">
    <div>
        <h5 class="mb-1" style="color: var(--secondary); font-weight: 700; font-size: 1.1rem;">
            <i class="bi bi-robot text-primary me-2"></i> Diagnóstico IA Concluído
        </h5>
        <p class="mb-0 text-muted" style="font-size: 0.9rem;">Sua análise estratégica personalizada já está disponível para leitura.</p>
    </div>
    <button class="btn btn-primary btn-sm px-4 py-2 fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#diagnosticModal">
        <i class="bi bi-book me-1"></i> Ler Diagnóstico
    </button>
</div>

<div class="mb-4">
    <h5 class="fw-bold mb-3" style="color: var(--secondary);">
        <i class="bi bi-lightning-charge-fill text-warning me-2"></i> Cockpit Inteligente
    </h5>
    
    <div class="row g-3" id="cockpit-cards">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid var(--warning) !important;">
                <div class="card-body py-3 d-flex align-items-center">
                    <div class="me-3" style="font-size: 1.8rem; color: var(--warning);">📦</div>
                    <div>
                        <h6 class="mb-1 text-muted" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 700;">Estoque</h6>
                        <p class="mb-0 fw-semibold cockpit-text" id="ai-estoque" style="font-size: 0.9rem; color: var(--text-main);">
                            <span class="spinner-border spinner-border-sm text-warning" role="status"></span> Analisando...
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid var(--danger) !important;">
                <div class="card-body py-3 d-flex align-items-center">
                    <div class="me-3" style="font-size: 1.8rem; color: var(--danger);">💸</div>
                    <div>
                        <h6 class="mb-1 text-muted" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 700;">Financeiro</h6>
                        <p class="mb-0 fw-semibold cockpit-text" id="ai-financeiro" style="font-size: 0.9rem; color: var(--text-main);">
                            <span class="spinner-border spinner-border-sm text-danger" role="status"></span> Calculando...
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid var(--success) !important;">
                <div class="card-body py-3 d-flex align-items-center">
                    <div class="me-3" style="font-size: 1.8rem; color: var(--success);">🚀</div>
                    <div>
                        <h6 class="mb-1 text-muted" style="font-size: 0.8rem; text-transform: uppercase; font-weight: 700;">Vendas</h6>
                        <p class="mb-0 fw-semibold cockpit-text" id="ai-vendas" style="font-size: 0.9rem; color: var(--text-main);">
                            <span class="spinner-border spinner-border-sm text-success" role="status"></span> Projetando...
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="diagnosticModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header" style="background-color: var(--primary-light); border-bottom: 1px solid #e2e8f0;">
                <h5 class="modal-title fw-bold" style="color: var(--secondary);">
                    <i class="bi bi-stars text-primary me-2"></i> Análise Estratégica StoreHost AI
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 p-md-5">
                <div id="diagnostic-content" style="font-size: 1rem; line-height: 1.8; color: var(--text-main); white-space: pre-wrap;">
                    </div>
                <span class="d-none" id="raw-diagnostic">{{storeDiagnostic}}</span>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const rawEl = document.getElementById("raw-diagnostic");
        const contentEl = document.getElementById("diagnostic-content");
        
        if (rawEl && contentEl) {
            let texto = rawEl.innerHTML;
            
            // Substitui os **asteriscos duplos** por tags <strong> de negrito do HTML
            texto = texto.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            
            // Joga o texto formatado limpo para a tela
            contentEl.innerHTML = texto;
        }
    });
</script>
{{/if}}


<!-- Grid Principal (Gráficos) -->
<div class="main-grid mb-4">
    <!-- Gráfico de Linha (Faturamento Mensal) -->
    <div class="data-card">
        <div class="card-header">
            <h2>Visão de Faturamento (Ano Corrente)</h2>
        </div>
        <div style="position: relative; height: 300px; width: 100%;">
            <canvas id="chartFaturamento"></canvas>
        </div>
    </div>

    <!-- Gráfico de Rosca (Despesas por Categoria) -->
    <div class="data-card">
        <div class="card-header">
            <h2>Despesas por Categoria</h2>
        </div>
        <div style="position: relative; height: 300px; width: 100%;">
            <canvas id="chartDespesas"></canvas>
        </div>
    </div>
</div>

<!-- Tabelas e Feed Operacional -->
<div class="main-grid">
    <!-- Tabela de Últimas Vendas -->
    <div class="data-card">
        <div class="card-header">
            <h2>Últimas Vendas Realizadas</h2>
            <a href="/dashboard/sales" class="btn-view">Ver Todas</a>
        </div>
        <div class="table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Qtd</th>
                        <th>Total</th>
                        <th>Método</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each ultimasVendas}}
                    <tr>
                        <td><strong>{{this.product_name}}</strong></td>
                        <td>{{this.quantity}}</td>
                        <td><strong style="color: var(--success);">R$ {{this.total_price}}</strong></td>
                        <td><span class="badge-status" style="background: #E2E8F0; color: #475569;">{{this.payment_method}}</span></td>
                        <td style="color: var(--text-muted); font-size: 0.85rem;">{{this.data_formatada}}</td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-muted);">
                            Nenhuma venda registrada recentemente.
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Feed de Últimas Movimentações de Estoque -->
    <div class="data-card">
        <div class="card-header">
            <h2>Movimentações de Estoque</h2>
            <a href="/dashboard/stock" class="btn-view">Ver Estoque</a>
        </div>
        <div style="padding-top: 1rem;">
            {{#each ultimasMovimentacoes}}
            <div class="activity-item">
                <div class="activity-dot" style="background-color: {{#if this.isEntrada}}var(--success){{else}}var(--danger){{/if}}; border-color: {{#if this.isEntrada}}#DCFCE7{{else}}#FEE2E2{{/if}};"></div>
                <div class="activity-content">
                    <p>
                        <strong>{{this.tipo_texto}}:</strong> {{this.productName}} 
                        <span style="font-weight: 600;">({{this.quantity}} unid.)</span>
                    </p>
                    <span>{{this.data_formatada}}</span>
                </div>
            </div>
            {{else}}
            <p style="text-align: center; padding: 2rem; color: var(--text-muted);">
                Nenhuma movimentação de estoque registrada.
            </p>
            {{/each}}
        </div>
    </div>
</div>

{{#unless onboardingCompleted}}
<div class="modal fade" id="onboardingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-top: 5px solid var(--primary);">
            <div class="modal-header border-0 pb-0">
                <h4 class="modal-title fw-bold text-center w-100">Bem-vindo(a) ao StoreHost! 🎉</h4>
            </div>
            <div class="modal-body text-center pt-2">
                <p class="text-muted mb-4">Para que a nossa Inteligência Artificial possa ajudá-lo de forma precisa, conte-nos um pouco sobre a sua loja.</p>
                
                <form id="onboardingForm">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">Qual o segmento da loja?</label>
                        <input type="text" id="ob-segmento" class="form-control" placeholder="Ex: Vestuário, Eletrónica, Alimentação..." required>
                    </div>
                    <div class="mb-3 text-start">
                        <label class="form-label fw-semibold">Ticket Médio (R$)</label>
                        <input type="number" id="ob-ticket" class="form-control" placeholder="Ex: 150.00" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3 text-start">
                            <label class="form-label fw-semibold">Cidade e Estado</label>
                            <input type="text" id="ob-cidade" class="form-control" placeholder="Ex: Salvador, BA" required>
                        </div>
                        <div class="col-md-6 mb-3 text-start">
                            <label class="form-label fw-semibold">Nº de Funcionários</label>
                            <input type="number" id="ob-funcionarios" class="form-control" placeholder="Ex: 3" required>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 mt-3 py-2" id="btn-gerar-diagnostico">
                        <i class="bi bi-stars"></i> Gerar Diagnóstico com IA
                    </button>
                </form>
                
                <div id="loading-ia" class="d-none mt-4 text-center">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 fw-semibold text-primary">A nossa IA está a analisar o seu mercado...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Mostra o modal automaticamente se o onboarding não estiver concluído
        const obModalEl = document.getElementById('onboardingModal');
        if (obModalEl) {
            const obModal = new bootstrap.Modal(obModalEl);
            obModal.show();

            document.getElementById('onboardingForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Esconde botão e mostra carregamento
                document.getElementById('btn-gerar-diagnostico').classList.add('d-none');
                document.getElementById('loading-ia').classList.remove('d-none');

                const payload = {
                    segmento: document.getElementById('ob-segmento').value,
                    ticket: document.getElementById('ob-ticket').value,
                    cidade: document.getElementById('ob-cidade').value,
                    funcionarios: document.getElementById('ob-funcionarios').value
                };

                try {
                    const response = await fetch('/api/ai-diagnostic', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (response.ok) {
                        window.location.reload(); // Recarrega a página para exibir o diagnóstico guardado
                    } else {
                        alert("Houve um erro ao processar. Tente novamente.");
                        window.location.reload();
                    }
                } catch (error) {
                    console.error(error);
                }
            });
        }
    });
</script>
{{/unless}}



<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>



<script>
document.addEventListener('DOMContentLoaded', function() {
    
    // =======================================================
    // 1. GRÁFICO DE LINHA: Faturamento Mensal (Area)
    // =======================================================
    const labelsFaturamento = {{{ labelsFaturamento }}};
    const dadosFaturamento = {{{ dadosFaturamento }}};
    const ctxArea = document.getElementById('chartFaturamento');
    
    if (ctxArea) {
        const gradientArea = ctxArea.getContext('2d').createLinearGradient(0, 0, 0, 300);
        gradientArea.addColorStop(0, 'rgba(10, 87, 232, 0.3)'); // Primary color light opacity
        gradientArea.addColorStop(1, 'rgba(10, 87, 232, 0.0)');

        new Chart(ctxArea, {
            type: 'line',
            data: {
                labels: labelsFaturamento.length > 0 ? labelsFaturamento : ['Sem Dados'],
                datasets: [{
                    label: 'Faturamento (R$)',
                    data: dadosFaturamento.length > 0 ? dadosFaturamento : [0], 
                    backgroundColor: gradientArea,
                    borderColor: '#0A57E8', // Primary
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#0A57E8',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#0D244F',
                        padding: 12,
                        titleFont: { size: 13 },
                        bodyFont: { size: 14, weight: 'bold' },
                        callbacks: {
                            label: function(context) {
                                return ' R$ ' + context.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#64748b' }
                    },
                    y: {
                        grid: { color: '#E2E8F0', borderDash: [5, 5] },
                        ticks: {
                            color: '#64748b',
                            callback: function(value) { return 'R$ ' + value; }
                        },
                        beginAtZero: true
                    }
                }
            }
        });
    }

    // =======================================================
    // 2. GRÁFICO DE ROSCA: Despesas por Categoria
    // =======================================================
    const labelsDespesas = {{{ labelsDespesas }}};
    const dadosDespesas = {{{ dadosDespesas }}};
    const ctxPie = document.getElementById('chartDespesas');
    
    if (ctxPie) {
        const hasData = labelsDespesas.length > 0;
        
        new Chart(ctxPie, {
            type: 'doughnut',
            data: {
                labels: hasData ? labelsDespesas : ['Sem Despesas'],
                datasets: [{
                    data: hasData ? dadosDespesas : [1],
                    backgroundColor: hasData ? [
                        '#EF4444', // Danger
                        '#F59E0B', // Warning
                        '#0A57E8', // Primary
                        '#10B981', // Success
                        '#8B5CF6', // Purple
                        '#EC4899'  // Pink
                    ] : ['#E2E8F0'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            boxWidth: 12,
                            padding: 15,
                            font: { size: 11 }
                        }
                    },
                    tooltip: {
                        enabled: hasData,
                        backgroundColor: '#0D244F',
                        padding: 12,
                        callbacks: {
                            label: function(context) {
                                return ' ' + context.label + ': R$ ' + context.parsed.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                            }
                        }
                    }
                }
            }
        });
    }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", async () => {
    // 🚀 Script AJAX para buscar os Alertas do Cockpit Proativo em background
    try {
        const response = await fetch('/api/cockpit');
        if (response.ok) {
            const data = await response.json();
            
            // Injeta as respostas da IA nos cartões, substituindo o "Carregando..."
            if(document.getElementById('ai-estoque')) document.getElementById('ai-estoque').innerText = data.alerta_estoque;
            if(document.getElementById('ai-financeiro')) document.getElementById('ai-financeiro').innerText = data.alerta_financeiro;
            if(document.getElementById('ai-vendas')) document.getElementById('ai-vendas').innerText = data.alerta_vendas;
        } else {
            throw new Error("Falha na API do Cockpit");
        }
    } catch (error) {
        console.error("Erro ao carregar o Cockpit da IA:", error);
        
        // Mensagem de segurança caso a IA demore ou a rota falhe
        const fallbackMsg = "Sistema operando normalmente.";
        if(document.getElementById('ai-estoque')) document.getElementById('ai-estoque').innerText = fallbackMsg;
        if(document.getElementById('ai-financeiro')) document.getElementById('ai-financeiro').innerText = fallbackMsg;
        if(document.getElementById('ai-vendas')) document.getElementById('ai-vendas').innerText = fallbackMsg;
    }
});
</script>