<div class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Visão geral</h1>
      <p class="mt-1 text-sm text-slate-500 max-w-2xl">
        Bem-vindo(a) de volta! Uma leitura instantânea da saúde da sua loja em tempo real.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <button onclick="document.getElementById('ia-diag-modal').classList.remove('hidden');" class="h-9 px-4 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-indigo-500 shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all flex items-center gap-2">
        <i data-lucide="sparkles" class="h-4 w-4"></i> Diagnóstico IA
      </button>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm overflow-hidden relative group">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <div class="h-8 w-8 rounded-lg grid place-items-center bg-indigo-50 text-indigo-600">
          <i data-lucide="sparkles" class="h-4 w-4 animate-pulse"></i>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-[0.25em] font-bold text-slate-400">Destaques da IA</div>
          <h3 class="font-bold text-slate-900 text-base">Central de Comando Inteligente</h3>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1">
          <button class="h-7 w-7 grid place-items-center rounded-md border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors" onclick="mudarSlideDashboard(-1)">
            <i data-lucide="chevron-left" class="h-4 w-4"></i>
          </button>
          <button class="h-7 w-7 grid place-items-center rounded-md border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors" onclick="mudarSlideDashboard(1)">
            <i data-lucide="chevron-right" class="h-4 w-4"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="relative min-h-[144px]">
      
      <div class="dash-ai-slide block transition-all duration-300">
        <div class="flex flex-col lg:flex-row gap-4 items-start lg:items-center rounded-xl border border-indigo-100 bg-indigo-50/40 p-4">
          <div class="w-full lg:w-1/4 h-32 rounded-lg bg-white flex flex-col items-center justify-center border border-indigo-200/60 shrink-0 text-indigo-600">
            <i data-lucide="trophy" class="h-10 w-10 animate-pulse"></i>
            <span class="text-[10px] uppercase font-bold tracking-wider text-slate-500 mt-2">Visão de Vendas</span>
          </div>
          <div class="flex-1">
            <div class="text-xs uppercase tracking-[0.2em] font-bold text-indigo-600 flex items-center gap-1">
              <i data-lucide="trending-up" class="h-3.5 w-3.5"></i> Insight de Conversão
            </div>
            <div id="ai-vendas" class="mt-2 text-lg font-bold text-slate-900 leading-tight">
              <span class="inline-block animate-pulse h-6 w-48 bg-slate-200 rounded"></span>
            </div>
            <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-white border border-slate-200 px-3 py-1 text-xs font-bold text-slate-600 shadow-sm">
              <i data-lucide="activity" class="h-3.5 w-3.5 text-indigo-600"></i>
              Processado pelo Gemini AI
            </div>
          </div>
        </div>
      </div>

      <div class="dash-ai-slide hidden transition-all duration-300">
        <div class="flex flex-col lg:flex-row gap-4 items-start lg:items-center rounded-xl border border-amber-100 bg-amber-50/40 p-4">
          <div class="w-full lg:w-1/4 h-32 rounded-lg bg-white flex flex-col items-center justify-center border border-amber-200/60 shrink-0 text-amber-500">
            <i data-lucide="package-search" class="h-10 w-10"></i>
            <span class="text-[10px] uppercase font-bold tracking-wider text-slate-500 mt-2">Visão de Estoque</span>
          </div>
          <div class="flex-1">
            <div class="text-xs uppercase tracking-[0.2em] font-bold text-amber-600 flex items-center gap-1">
              <i data-lucide="alert-triangle" class="h-3.5 w-3.5"></i> Alerta Logístico
            </div>
            <div id="ai-estoque" class="mt-2 text-lg font-bold text-slate-900 leading-tight">
              <span class="inline-block animate-pulse h-6 w-48 bg-slate-200 rounded"></span>
            </div>
            <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-white border border-slate-200 px-3 py-1 text-xs font-bold text-slate-600 shadow-sm">
              <i data-lucide="boxes" class="h-3.5 w-3.5 text-amber-600"></i>
              Processado pelo Gemini AI
            </div>
          </div>
        </div>
      </div>

      <div class="dash-ai-slide hidden transition-all duration-300">
        <div class="flex flex-col lg:flex-row gap-4 items-start lg:items-center rounded-xl border border-rose-100 bg-rose-50/40 p-4">
          <div class="w-full lg:w-1/4 h-32 rounded-lg bg-white flex flex-col items-center justify-center border border-rose-200/60 shrink-0 text-rose-500">
            <i data-lucide="pie-chart" class="h-10 w-10"></i>
            <span class="text-[10px] uppercase font-bold tracking-wider text-slate-500 mt-2">Visão Financeira</span>
          </div>
          <div class="flex-1">
            <div class="text-xs uppercase tracking-[0.2em] font-bold text-rose-600 flex items-center gap-1">
              <i data-lucide="wallet" class="h-3.5 w-3.5"></i> Fluxo de Caixa
            </div>
            <div id="ai-financeiro" class="mt-2 text-lg font-bold text-slate-900 leading-tight">
              <span class="inline-block animate-pulse h-6 w-48 bg-slate-200 rounded"></span>
            </div>
            <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-white border border-slate-200 px-3 py-1 text-xs font-bold text-slate-600 shadow-sm">
              <i data-lucide="calculator" class="h-3.5 w-3.5 text-rose-600"></i>
              Processado pelo Gemini AI
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="flex items-center justify-center gap-1.5 mt-4">
      <span class="dash-ai-dot h-1.5 w-4 rounded-full bg-indigo-600 transition-all"></span>
      <span class="dash-ai-dot h-1.5 w-1.5 rounded-full bg-slate-200 transition-all"></span>
      <span class="dash-ai-dot h-1.5 w-1.5 rounded-full bg-slate-200 transition-all"></span>
    </div>
  </div>

  <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Receita Acumulada</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-emerald-50 text-emerald-600">
          <i data-lucide="wallet" class="h-4 w-4"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">
        R$ {{kpiVendas}}
      </div>
      <div class="mt-1 text-xs font-bold text-slate-500">Valor total bruto</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Despesas Totais</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-rose-50 text-rose-600">
          <i data-lucide="trending-down" class="h-4 w-4"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">
        R$ {{kpiDespesas}}
      </div>
      <div class="mt-1 text-xs font-bold text-slate-500">Saídas financeiras registadas</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Produtos no Catálogo</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-indigo-50 text-indigo-600">
          <i data-lucide="boxes" class="h-4 w-4"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">
        {{kpiProdutos}}
      </div>
      <div class="mt-1 text-xs font-bold text-slate-500">Itens cadastrados na loja</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Estoque Crítico</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-amber-50 text-amber-600">
          <i data-lucide="alert-triangle" class="h-4 w-4"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">
        {{kpiEstoqueBaixo}}
      </div>
      <div class="mt-1 text-xs font-bold text-amber-600">Abaixo do nível ideal</div>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 lg:col-span-2 shadow-sm">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="text-[11px] uppercase tracking-[0.25em] font-bold text-slate-400 flex items-center gap-1.5">
            Evolução Mensal
          </div>
          <h2 class="mt-1 text-lg font-bold text-slate-900">Histórico de Faturamento (Ano Corrente)</h2>
        </div>
      </div>

      <div class="h-72 rounded-xl border border-slate-200 bg-slate-50/50 p-4 relative w-full">
        <canvas id="chartFaturamento"></canvas>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col">
      <div class="text-[11px] uppercase tracking-[0.25em] font-bold text-slate-400">Atividade recente</div>
      <h3 class="mt-1 text-lg font-bold text-slate-900">Últimas Transações</h3>
      
      <ul class="mt-4 space-y-3 flex-1 overflow-y-auto">
        {{#each ultimasVendas}}
        <li class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 transition-colors border border-transparent hover:border-slate-100">
          <div class="h-10 w-10 shrink-0 rounded-lg grid place-items-center text-xs font-bold bg-emerald-50 text-emerald-600">
            <i data-lucide="shopping-bag" class="h-5 w-5"></i>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-bold text-slate-800 truncate">{{this.product_name}}</div>
            <div class="text-xs text-slate-500">{{this.quantity}} un · {{this.data_formatada}}</div>
          </div>
          <div class="text-sm font-bold text-slate-900 tabular-nums">R$ {{this.total_price}}</div>
        </li>
        {{else}}
        <div class="flex flex-col items-center justify-center h-full text-center text-slate-400">
          <i data-lucide="inbox" class="h-8 w-8 mb-2"></i>
          <p class="text-sm">Nenhuma venda registada recentemente.</p>
        </div>
        {{/each}}
      </ul>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="relative overflow-hidden rounded-2xl border border-indigo-100 bg-indigo-50/40 p-6 shadow-xs h-full">
      <div class="absolute -top-16 -right-16 h-40 w-40 rounded-full blur-3xl opacity-60 bg-indigo-200"></div>
      <div class="relative">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-indigo-100 px-2.5 py-1 text-[11px] font-bold text-indigo-700 shadow-xs">
          <i data-lucide="brain" class="h-3 w-3"></i>
          Análise Estratégica AI
        </div>
        <h3 class="mt-3 text-base font-bold text-slate-900 flex items-center gap-2">
          Resumo do Negócio
        </h3>
        
        {{#if storeDiagnostic}}
          <div id="diagnostic-content-view" class="mt-3 text-sm text-slate-700 leading-relaxed whitespace-pre-wrap"></div>
          <span class="hidden" id="raw-diagnostic">{{storeDiagnostic}}</span>
        {{else}}
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">
            Nós usamos o <span class="font-bold text-slate-900">Google Gemini</span> para analisar o seu modelo de negócio, ticket médio e quadro de funcionários para lhe fornecer insights exclusivos de otimização.<br><br>
            Clique no botão <strong>"Diagnóstico IA"</strong> no topo da página para gerar o seu perfil.
          </p>
        {{/if}}
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-xs h-full">
      <div class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-bold text-slate-600 shadow-xs">
        <i data-lucide="boxes" class="h-3 w-3"></i>
        Logística
      </div>
      <h3 class="mt-3 text-base font-bold text-slate-900 flex items-center gap-2">
        Últimas Movimentações de Estoque
      </h3>
      <div class="mt-4 space-y-3">
        {{#each ultimasMovimentacoes}}
          <div class="flex items-center justify-between p-2 rounded-lg bg-slate-50 border border-slate-100">
            <div class="flex items-center gap-3">
              {{#if this.isEntrada}}
                <div class="h-8 w-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center"><i data-lucide="arrow-down-to-line" class="h-4 w-4"></i></div>
              {{else}}
                <div class="h-8 w-8 rounded-full bg-rose-100 text-rose-600 flex items-center justify-center"><i data-lucide="arrow-up-from-line" class="h-4 w-4"></i></div>
              {{/if}}
              <div>
                <p class="text-sm font-bold text-slate-800">{{this.productName}}</p>
                <p class="text-xs text-slate-500">{{this.data_formatada}}</p>
              </div>
            </div>
            <div class="text-right">
              <span class="text-sm font-bold {{#if this.isEntrada}}text-emerald-600{{else}}text-rose-600{{/if}}">
                {{#if this.isEntrada}}+{{else}}-{{/if}}{{this.quantity}} un
              </span>
            </div>
          </div>
        {{else}}
          <p class="text-sm text-slate-500">Nenhuma movimentação de estoque registada.</p>
        {{/each}}
      </div>
    </div>
  </section>

  <div id="ia-diag-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
    <div class="mx-auto flex min-h-full max-w-2xl items-center justify-center">
      <div class="w-full rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-2.5 py-1 text-[11px] font-bold text-indigo-600">
              <i data-lucide="sparkles" class="h-3 w-3"></i>
              Diagnóstico com IA
            </div>
            <h3 class="mt-3 text-xl font-bold text-slate-900">Diagnóstico Rápido da sua Loja</h3>
            <p class="mt-2 text-sm text-slate-500">Preencha os dados do seu negócio para gerarmos um parecer estratégico.</p>
          </div>
          <button type="button" onclick="document.getElementById('ia-diag-modal').classList.add('hidden')" class="h-9 w-9 rounded-lg border border-slate-200 bg-slate-50 text-slate-500 hover:bg-slate-100 transition-colors flex items-center justify-center">
            <i data-lucide="x" class="h-4 w-4"></i>
          </button>
        </div>

        <form id="onboardingForm" class="mt-6 space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Segmento da loja</label>
              <input type="text" id="ob-segmento" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="Moda, calçados, cosméticos..." required />
            </div>
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Ticket médio (R$)</label>
              <input type="number" id="ob-ticket" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="Ex: 150" required />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Cidade / Estado</label>
              <input type="text" id="ob-cidade" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="São Paulo - SP" required />
            </div>
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Nº de funcionários</label>
              <input type="number" id="ob-funcionarios" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="Ex: 3" required />
            </div>
          </div>
          
          <div id="loading-ia" class="hidden mt-4 bg-indigo-50 text-indigo-700 p-3 rounded-lg flex items-center justify-center gap-2 text-sm font-bold">
            <i data-lucide="loader" class="h-4 w-4 animate-spin"></i> O Gemini está a analisar o seu mercado...
          </div>

          <div class="flex flex-wrap items-center justify-end gap-3 pt-2">
            <button type="button" onclick="document.getElementById('ia-diag-modal').classList.add('hidden')" class="h-10 rounded-lg border border-slate-200 bg-slate-50 px-4 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors">
              Cancelar
            </button>
            <button type="submit" id="btn-gerar-diagnostico" class="h-10 rounded-lg bg-gradient-to-r from-indigo-600 to-indigo-500 px-4 text-sm font-bold text-white shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all flex items-center gap-2">
              <i data-lucide="sparkles" class="h-4 w-4"></i> Analisar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // 1. LÓGICA DO SLIDER (Mantida e Melhorada)
  let dashSlideIndex = 0;
  function mudarSlideDashboard(n) {
    const slides = document.querySelectorAll('.dash-ai-slide');
    const dots = document.querySelectorAll('.dash-ai-dot');
    if (!slides.length) return;
    
    slides[dashSlideIndex].classList.replace('block', 'hidden');
    dots[dashSlideIndex].classList.replace('w-4', 'w-1.5');
    dots[dashSlideIndex].classList.replace('bg-indigo-600', 'bg-slate-200');
    
    dashSlideIndex = (dashSlideIndex + n + slides.length) % slides.length;
    
    slides[dashSlideIndex].classList.replace('hidden', 'block');
    dots[dashSlideIndex].classList.replace('w-1.5', 'w-4');
    dots[dashSlideIndex].classList.replace('bg-slate-200', 'bg-indigo-600');
  }
  setInterval(() => mudarSlideDashboard(1), 8000);

  document.addEventListener('DOMContentLoaded', async () => {
    // Renderiza os ícones novos do Lucide injetados dinamicamente
    if (window.lucide) window.lucide.createIcons();

    // 2. CHART.JS (Gráfico de Área)
    const labelsStr = '{{{labelsFaturamento}}}';
    const dadosStr = '{{{dadosFaturamento}}}';
    
    if(labelsStr && dadosStr && document.getElementById('chartFaturamento')) {
      const labels = JSON.parse(labelsStr);
      const dados = JSON.parse(dadosStr);

      new Chart(document.getElementById('chartFaturamento').getContext('2d'), {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Faturamento (R$)',
            data: dados,
            borderColor: '#6366f1', // Indigo-600
            backgroundColor: 'rgba(99, 102, 241, 0.1)',
            borderWidth: 3,
            fill: true,
            tension: 0.4, // Curvas suaves
            pointBackgroundColor: '#ffffff',
            pointBorderColor: '#6366f1',
            pointBorderWidth: 2,
            pointRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { display: false } },
            y: { grid: { borderDash: [5, 5], color: '#e2e8f0' }, beginAtZero: true }
          }
        }
      });
    }

    // 3. FORMATAÇÃO DO DIAGNÓSTICO IA (Negritos Markdown)
    const rawDiag = document.getElementById("raw-diagnostic");
    const viewDiag = document.getElementById("diagnostic-content-view");
    if (rawDiag && viewDiag) {
        let texto = rawDiag.innerHTML;
        texto = texto.replace(/\*\*(.*?)\*\*/g, '<strong class="text-slate-900">$1</strong>');
        viewDiag.innerHTML = texto;
    }

    // 4. ENVIO DO FORMULÁRIO DO DIAGNÓSTICO
    const diagForm = document.getElementById('onboardingForm');
    if(diagForm) {
      diagForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        document.getElementById('btn-gerar-diagnostico').classList.add('hidden');
        document.getElementById('loading-ia').classList.remove('hidden');
        document.getElementById('loading-ia').classList.add('flex');

        const payload = {
          segmento: document.getElementById('ob-segmento').value,
          ticket: document.getElementById('ob-ticket').value,
          cidade: document.getElementById('ob-cidade').value,
          funcionarios: document.getElementById('ob-funcionarios').value
        };

        try {
          const res = await fetch('/api/ai-diagnostic', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          if (res.ok) window.location.reload();
          else alert("Erro ao processar dados com a IA.");
        } catch (err) {
          console.error(err);
        }
      });
    }

    // 5. CHAMADA AJAX DO COCKPIT (Preenche os slides da IA)
    try {
        const response = await fetch('/api/cockpit');
        if (response.ok) {
            const data = await response.json();
            
            const estoqueEl = document.getElementById('ai-estoque');
            const financeiroEl = document.getElementById('ai-financeiro');
            const vendasEl = document.getElementById('ai-vendas');

            if(estoqueEl) estoqueEl.innerText = data.alerta_estoque;
            if(financeiroEl) financeiroEl.innerText = data.alerta_financeiro;
            if(vendasEl) vendasEl.innerText = data.alerta_vendas;
        }
    } catch (error) {
        console.log("Erro Cockpit:", error);
        // Fallback seguro se a IA demorar muito
        const fb = "Sistema operando sob parâmetros normais.";
