<section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    {{#each funcionarios}}
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-3">
        <div class="h-12 w-12 rounded-full bg-gradient-to-r from-indigo-600 to-indigo-500 grid place-items-center text-white font-bold shadow-sm shadow-indigo-500/10 shrink-0">
          {{this.iniciais}}
        </div>
        <div class="min-w-0 flex-1">
          <div class="font-bold truncate text-slate-900">{{this.name}}</div>
          <div class="text-xs font-medium text-slate-400">{{this.cargo}}</div>
        </div>
      </div>
      <div class="mt-4 space-y-1.5 text-xs text-slate-500">
        <div class="flex items-center gap-2"><i data-lucide="mail" class="h-3.5 w-3.5 text-slate-400"></i> {{this.email}}</div>
        <div class="flex items-center gap-2"><i data-lucide="phone" class="h-3.5 w-3.5 text-slate-400"></i> {{this.telefone}}</div>
      </div>
      <div class="mt-4">
        <div class="flex justify-between text-xs mb-1.5 text-slate-500">
          <span>Meta do mês</span>
          <span class="font-bold text-slate-900">{{this.vendas}} / {{this.meta}}</span>
        </div>
        <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
          <div class="h-full rounded-full bg-indigo-600" style="width: {{this.pct}}%"></div>
        </div>
        <div class="mt-1 text-[11px] font-medium text-slate-400">{{this.pct}}% concluído</div>
      </div>
    </div>
    {{else}}
    <div class="col-span-full py-12 text-center text-slate-500">
      <i data-lucide="users" class="h-10 w-10 mx-auto mb-3 opacity-50"></i>
      <p>Nenhum colaborador registado na loja.</p>
    </div>
    {{/each}}
  </section>