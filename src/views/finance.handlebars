<div class="space-y-6 p-4 sm:p-6 max-w-[1600px] mx-auto">
  
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Gestão financeira</h1>
      <p class="mt-1 text-sm text-slate-500 max-w-2xl">
        Fluxo de caixa, categorização de despesas e insights profundos de IA.
      </p>
    </div>
  </div>

  <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Saldo em caixa</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-indigo-50 text-indigo-600">
          <i class="bi bi-wallet2 text-base"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">R$ {{saldoFinal}}</div>
      <div class="mt-1 text-xs font-bold text-emerald-600">+18,3% no mês</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Receita total</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-indigo-50 text-indigo-600">
          <i class="bi bi-graph-up-arrow text-base"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">R$ {{totalEntradas}}</div>
      <div class="mt-1 text-xs font-bold text-emerald-600">+13,2% no mês</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Despesas total</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-indigo-50 text-indigo-600">
          <i class="bi bi-graph-down-arrow text-base"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">R$ {{totalSaidas}}</div>
      <div class="mt-1 text-xs font-bold text-rose-600">+7,3% no mês</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md">
      <div class="flex items-start justify-between">
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Lucro Líquido</div>
        <div class="h-9 w-9 grid place-items-center rounded-lg bg-indigo-50 text-indigo-600">
          <i class="bi bi-lightning-charge text-base"></i>
        </div>
      </div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">{{taxaEficiencia}}</div>
      <div class="mt-1 text-xs font-bold text-emerald-600">+2,1 p.p.</div>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 lg:col-span-2 shadow-sm">
      <h3 class="text-base font-bold text-slate-900 mb-4">Fluxo de caixa — Proporção Geral</h3>
      <div class="h-72 rounded-xl border border-slate-100 bg-slate-50/50 p-4 relative">
        <canvas id="chartResumo"></canvas>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col justify-between">
      <div>
        <h3 class="text-base font-bold text-slate-900 mb-4">Despesas por categoria</h3>
        <div class="h-32 relative mb-4">
          <canvas id="chartSaidas"></canvas>
        </div>
      </div>
      <div class="border-t border-slate-100 pt-4">
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Entradas por categoria</h3>
        <div class="h-24 relative">
          <canvas id="chartEntradas"></canvas>
        </div>
      </div>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm lg:col-span-2 flex flex-col justify-between overflow-hidden">
      <div>
        <div class="p-6 border-b border-slate-100 flex flex-wrap items-center justify-between gap-4">
          <h3 class="text-base font-bold text-slate-900">Histórico de Transações</h3>
          
          <div class="relative w-full sm:w-72">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
              <i class="bi bi-search"></i>
            </span>
            <input type="text" id="searchInput" class="w-full pl-9 pr-4 py-2 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" placeholder="Buscar descrição ou categoria...">
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse" id="financeTable">
            <thead>
              <tr class="border-b border-slate-100 bg-slate-50/70 text-xs font-bold uppercase tracking-wider text-slate-400">
                <th class="py-3 px-4">Data</th>
                <th class="py-3 px-4">Descrição</th>
                <th class="py-3 px-4">Categoria</th>
                <th class="py-3 px-4">Tipo</th>
                <th class="py-3 px-4">Valor</th>
                <th class="py-3 px-4 text-center">Ações</th>
              </tr>
            </thead>
            <tbody id="tableBody" class="divide-y divide-slate-100 text-sm">
              {{#each transacoes}}
                <tr class="finance-row hover:bg-slate-50/50 transition" data-search="{{this.description}} {{this.category}} {{#if this.isIncome}}entrada receita{{else}}saída despesa{{/if}}">
                  <td class="py-3.5 px-4 text-slate-500 font-medium whitespace-nowrap">{{this.data_formatada}}</td>
                  <td class="py-3.5 px-4 font-bold text-slate-800">{{this.description}}</td>
                  <td class="py-3.5 px-4"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800 border border-slate-200">{{this.category}}</span></td>
                  <td class="py-3.5 px-4">
                    {{#if this.isIncome}}
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Entrada
                      </span>
                    {{else}}
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-rose-50 text-rose-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span> Saída
                      </span>
                    {{/if}}
                  </td>
                  <td class="py-3.5 px-4 font-bold">
                    <span class="{{#if this.isIncome}}text-emerald-600{{else}}text-rose-600{{/if}}">
                      R$ {{this.amount}}
                    </span>
                  </td>
                  <td class="py-3.5 px-4">
                    <div class="flex items-center justify-center gap-2">
                      <button class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-bold rounded-xl border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition" 
                        onclick="openViewModal(this)"
                        data-description="{{this.description}}" 
                        data-category="{{this.category}}"
                        data-amount="{{this.amount}}" 
                        data-type="{{#if this.isIncome}}Entrada{{else}}Saída{{/if}}" 
                        data-date="{{this.data_formatada}}">
                        <i class="bi bi-eye"></i> Ver
                      </button>

                      <button class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-bold rounded-xl border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition" 
                        onclick="openEditModal(this)"
                        data-id="{{this._id}}" 
                        data-description="{{this.description}}" 
                        data-category="{{this.category}}"
                        data-amount="{{this.amount}}" 
                        data-type="{{#if this.isIncome}}income{{else}}expense{{/if}}">
                        Editar
                      </button>

                      <form action="/dashboard/finance/delete" method="POST" onsubmit="return confirm('Excluir este lançamento?')" class="m-0">
                        <input type="hidden" name="transaction_id" value="{{this._id}}">
                        <button type="submit" class="p-1 text-slate-400 hover:text-rose-600 rounded-lg hover:bg-rose-50 transition">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              {{else}}
                <tr id="emptyRow">
                  <td colspan="6" class="text-center py-12 text-slate-400 font-medium">
                    <i class="bi bi-journal-x text-2xl block mb-2 text-slate-300"></i>
                    Nenhuma transação registrada ainda.
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>    
        </div>
      </div>

      <div class="p-4 border-t border-slate-100 bg-slate-50/50 flex items-center justify-between" id="paginationControls">
        <button class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-semibold rounded-lg border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 disabled:opacity-50 transition" id="prevPage" disabled>
          <i class="bi bi-chevron-left"></i> Anterior
        </button>
        <span id="pageIndicator" class="text-xs font-bold text-slate-500">Página 1</span>
        <button class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-semibold rounded-lg border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition" id="nextPage">
          Próxima <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>

    <div class="space-y-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-base font-bold text-slate-900 mb-1">Novo Lançamento</h3>
        <p class="text-xs text-slate-400 mb-4">Insira despesas fixas, variáveis ou receitas avulsas da loja.</p>
        
        <div id="alert-container"></div>

        <form action="/dashboard/finance/create" method="post" class="space-y-3.5">
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Tipo de Lançamento</label>
            <select name="type" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
              <option value="income">Entrada (Receita)</option>
              <option value="expense">Saída (Despesa)</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Descrição</label>
            <input type="text" name="description" placeholder="Ex: Conta de Luz, Fornecedor..." class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Categoria</label>
            <input type="text" name="category" placeholder="Ex: Infraestrutura, Produtos..." class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Valor (R$)</label>
            <div class="relative rounded-xl shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 text-sm font-medium">R$</div>
              <input type="number" step="0.01" name="amount" placeholder="0.00" class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
            </div>
          </div>

          <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm rounded-xl shadow-sm hover:shadow transition">Salvar Transação</button>
        </form>
      </div>

      <div class="rounded-2xl border border-indigo-100 bg-indigo-50/30 p-5 shadow-sm relative overflow-hidden">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-indigo-100 px-2.5 py-1 text-[11px] font-bold text-indigo-700">
          <i class="bi bi-cpu text-xs"></i> Insight de IA
        </div>
        <h4 class="mt-2 text-sm font-bold text-slate-900">Reduza taxa de maquininha</h4>
        <p class="mt-1 text-xs text-slate-600 leading-relaxed">
          Você está pagando 3,49% enquanto a média do seu setor é 2,89%. Renegociando com o adquirente, a economia anual estimada é de R$ 8.640.
        </p>
      </div>
    </div>
  </section>
</div>

<div id="viewFinanceModal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-md items-center justify-center w-full">
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-xl overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
        <h5 class="font-bold text-slate-900 flex items-center gap-2">
          <i class="bi bi-file-earmark-text text-indigo-600"></i> Detalhes do Lançamento
        </h5>
        <button type="button" onclick="closeModal('viewFinanceModal')" class="text-slate-400 hover:text-slate-600 text-lg">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <div class="p-6 space-y-4 text-sm">
        <div class="border-b border-slate-100 pb-3">
          <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Descrição</label>
          <span id="view-fin-desc" class="font-bold text-slate-800 text-base"></span>
        </div>
        <div class="border-b border-slate-100 pb-3">
          <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Categoria</label>
          <span id="view-fin-cat" class="font-semibold text-slate-700 bg-slate-100 px-2.5 py-0.5 rounded-full text-xs border border-slate-200 inline-block"></span>
        </div>
        <div class="border-b border-slate-100 pb-3">
          <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Tipo</label>
          <span id="view-fin-type" class="font-semibold text-slate-700"></span>
        </div>
        <div class="border-b border-slate-100 pb-3">
          <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Valor</label>
          <span id="view-fin-amount" class="font-extrabold text-lg text-slate-900"></span>
        </div>
        <div>
          <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Data de Registro</label>
          <span id="view-fin-date" class="text-slate-500 font-medium"></span>
        </div>
      </div>
      <div class="px-6 py-3 border-t border-slate-100 bg-slate-50/50 flex justify-end">
        <button type="button" onclick="closeModal('viewFinanceModal')" class="px-4 py-2 text-xs font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded-xl transition">Fechar</button>
      </div>
    </div>
  </div>
</div>

<div id="editFinanceModal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-md items-center justify-center w-full">
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-xl overflow-hidden">
      <form id="editFinanceForm" method="POST">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
          <h5 class="font-bold text-slate-900 flex items-center gap-2">
            <i class="bi bi-pencil-square text-indigo-600"></i> Editar Lançamento
          </h5>
          <button type="button" onclick="closeModal('editFinanceModal')" class="text-slate-400 hover:text-slate-600 text-lg">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Tipo</label>
            <select name="type" id="edit-fin-type" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
              <option value="income">Entrada (Receita)</option>
              <option value="expense">Saída (Despesa)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Descrição</label>
            <input type="text" name="description" id="edit-fin-desc" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Categoria</label>
            <input type="text" name="category" id="edit-fin-cat" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Valor (R$)</label>
            <div class="relative rounded-xl shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 text-sm font-medium">R$</div>
              <input type="number" step="0.01" name="amount" id="edit-fin-amount" class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" required>
            </div>
          </div>
        </div>
        <div class="px-6 py-3 border-t border-slate-100 bg-slate-50/50 flex justify-end gap-2">
          <button type="button" onclick="closeModal('editFinanceModal')" class="px-4 py-2 text-xs font-bold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition">Cancelar</button>
          <button type="submit" class="px-4 py-2 text-xs font-bold bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl shadow transition">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // ==========================================
    // 0. LÓGICA DE CONTROLE DE MODAIS (Nativo Tailwind)
    // ==========================================
    function openModal(id) {
        const modal = document.getElementById(id);
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function closeModal(id) {
        const modal = document.getElementById(id);
        modal.classList.remove('flex');
        modal.classList.add('hidden');
    }

    function openViewModal(btnElement) {
        document.getElementById('view-fin-desc').textContent = btnElement.getAttribute('data-description');
        document.getElementById('view-fin-cat').textContent = btnElement.getAttribute('data-category');
        document.getElementById('view-fin-type').textContent = btnElement.getAttribute('data-type');
        document.getElementById('view-fin-amount').textContent = `R$ ${btnElement.getAttribute('data-amount')}`;
        document.getElementById('view-fin-date').textContent = btnElement.getAttribute('data-date');
        openModal('viewFinanceModal');
    }

    function openEditModal(btnElement) {
        document.getElementById('edit-fin-type').value = btnElement.getAttribute('data-type');
        document.getElementById('edit-fin-desc').value = btnElement.getAttribute('data-description');
        document.getElementById('edit-fin-cat').value = btnElement.getAttribute('data-category');
        document.getElementById('edit-fin-amount').value = btnElement.getAttribute('data-amount');
        document.getElementById('editFinanceForm').action = `/dashboard/finance/update/${btnElement.getAttribute('data-id')}`;
        openModal('editFinanceModal');
    }

    // ==========================================
    // 1. LÓGICA DE ALERTS
    // ==========================================
    const urlParams = new URLSearchParams(window.location.search);
    const alertContainer = document.getElementById('alert-container');

    if (urlParams.get('sucess') === 'create') {
        alertContainer.innerHTML = `
            <div class="p-3 mb-4 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-800 border border-emerald-200 flex items-center justify-between" role="alert">
                <div class="flex items-center gap-2"><i class="bi bi-check-circle-fill"></i> Lançamento Cadastrado Com Sucesso!</div>
                <button type="button" class="text-emerald-500 hover:text-emerald-700 font-bold" onclick="this.parentElement.style.display='none'">×</button>
            </div>`;
    } else if (urlParams.get('sucess') === 'update') {
        alertContainer.innerHTML = `
            <div class="p-3 mb-4 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-800 border border-emerald-200 flex items-center justify-between">
                <div class="flex items-center gap-2"><i class="bi bi-check-circle-fill"></i> Lançamento atualizado!</div>
                <button type="button" class="text-emerald-500 hover:text-emerald-700 font-bold" onclick="this.parentElement.style.display='none'">×</button>
            </div>`;
    } else if (urlParams.get('sucess') === 'delete') {
        alertContainer.innerHTML = `
            <div class="p-3 mb-4 rounded-xl text-sm font-medium bg-amber-50 text-amber-800 border border-amber-200 flex items-center justify-between">
                <div class="flex items-center gap-2"><i class="bi bi-exclamation-triangle-fill"></i> Lançamento removido com sucesso.</div>
                <button type="button" class="text-amber-500 hover:text-amber-700 font-bold" onclick="this.parentElement.style.display='none'">×</button>
            </div>`;
    }

    // ==========================================
    // 2. LÓGICA DOS GRÁFICOS
    // ==========================================
    const labelsEntradas = {{{ labelsEntradas }}};
    const dadosEntradas = {{{ dadosEntradas }}};
    const labelsSaidas = {{{ labelsSaidas }}};
    const dadosSaidas = {{{ dadosSaidas }}};
    const totalEntradas = {{ totalEntradas }};
    const totalSaidas = {{ totalSaidas }};

    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 11, family: 'system-ui' } } } }
    };

    new Chart(document.getElementById('chartEntradas'), {
        type: 'doughnut',
        data: {
            labels: labelsEntradas.length > 0 ? labelsEntradas : ['Sem Dados'],
            datasets: [{
                data: dadosEntradas.length > 0 ? dadosEntradas : [1], 
                backgroundColor: dadosEntradas.length > 0 ? ['#4f46e5', '#6366f1', '#818cf8', '#a5b4fc', '#c7d2fe'] : ['#f1f5f9'],
                borderWidth: 0
            }]
        },
        options: chartOptions
    });

    new Chart(document.getElementById('chartSaidas'), {
        type: 'doughnut',
        data: {
            labels: labelsSaidas.length > 0 ? labelsSaidas : ['Sem Dados'],
            datasets: [{
                data: dadosSaidas.length > 0 ? dadosSaidas : [1],
                backgroundColor: dadosSaidas.length > 0 ? ['#f43f5e', '#fb7185', '#fda4af', '#fecdd3', '#ffe4e6'] : ['#f1f5f9'],
                borderWidth: 0
            }]
        },
        options: chartOptions
    });

    new Chart(document.getElementById('chartResumo'), {
        type: 'pie',
        data: {
            labels: ['Entradas', 'Saídas'],
            datasets: [{
                data: (totalEntradas === 0 && totalSaidas === 0) ? [1] : [totalEntradas, totalSaidas],
                backgroundColor: (totalEntradas === 0 && totalSaidas === 0) ? ['#f1f5f9'] : ['#10b981', '#f43f5e'],
                borderWidth: 0
            }]
        },
        options: chartOptions
    });

    // ==========================================
    // 3. PESQUISA E PAGINAÇÃO
    // ==========================================
    document.addEventListener("DOMContentLoaded", function() {
        const searchInput = document.getElementById("searchInput");
        const allRows = Array.from(document.querySelectorAll(".finance-row")); 
        let filteredRows = [...allRows]; 
        let currentPage = 1;
        const rowsPerPage = 10; 

        const btnPrev = document.getElementById("prevPage");
        const btnNext = document.getElementById("nextPage");
        const pageIndicator = document.getElementById("pageIndicator");

        function renderTable() {
            allRows.forEach(row => row.style.display = "none");
            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const rowsToShow = filteredRows.slice(startIndex, endIndex);
            rowsToShow.forEach(row => row.style.display = ""); 

            const totalPages = Math.ceil(filteredRows.length / rowsPerPage) || 1;
            if(pageIndicator) pageIndicator.textContent = `Página ${currentPage} de ${totalPages}`;
            if(btnPrev) btnPrev.disabled = currentPage === 1;
            if(btnNext) btnNext.disabled = currentPage === totalPages;
        }

        if(searchInput) {
            searchInput.addEventListener("input", function(e) {
                const searchTerm = e.target.value.toLowerCase().trim();
                filteredRows = allRows.filter(row => {
                    const searchData = row.getAttribute("data-search").toLowerCase();
                    return searchData.includes(searchTerm);
                });
                currentPage = 1;
                renderTable();
            });
        }

        if(btnPrev) {
            btnPrev.addEventListener("click", () => {
                if (currentPage > 1) {
                    currentPage--;
                    renderTable();
                }
            });
        }

        if(btnNext) {
            btnNext.addEventListener("click", () => {
                const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
                if (currentPage < totalPages) {
                    currentPage++;
                    renderTable();
                }
            });
        }

        renderTable();
    });
</script>