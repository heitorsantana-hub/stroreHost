<div class="content-body">
    
    <section class="welcome-sec">
        <h1>Gestão Financeira</h1>
        <p>Acompanhe o fluxo de caixa, adicione receitas e registre despesas da loja.</p>
    </section>

    <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem;">
        <section class="stat-card" style="text-align: center;">
            <h3 style="margin-bottom: 1rem;">Distribuição de Entradas</h3>
            <div style="position: relative; height: 200px; width: 100%; display: flex; justify-content: center;">
                <canvas id="chartEntradas"></canvas>
            </div>
        </section>

        <section class="stat-card" style="text-align: center;">
            <h3 style="margin-bottom: 1rem;">Distribuição de Saídas</h3>
            <div style="position: relative; height: 200px; width: 100%; display: flex; justify-content: center;">
                <canvas id="chartSaidas"></canvas>
            </div>
        </section>

        <section class="stat-card" style="text-align: center;">
            <h3 style="margin-bottom: 1rem;">Entradas x Saídas</h3>
            <div style="position: relative; height: 200px; width: 100%; display: flex; justify-content: center;">
                <canvas id="chartResumo"></canvas>
            </div>
        </section>
    </div>
    
    <div class="main-grid">
        
        <section class="data-card">
            <div class="card-header">
                <h2>Histórico de Lançamentos</h2>
            </div>
            
            <div class="table-container">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Descrição</th>
                            <th>Categoria</th>
                            <th>Tipo</th>
                            <th>Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each transacoes}}
                            <tr>
                                <td style="color: var(--text-muted); font-size: 0.85rem;">{{this.data_formatada}}</td>
                                <td><strong>{{this.description}}</strong></td>
                                <td>{{this.category}}</td>
                                <td>
                                    {{#if this.isIncome}}
                                        <span class="badge-status" style="background: #DCFCE7; color: #166534;">Entrada</span>
                                    {{else}}
                                        <span class="badge-status" style="background: #FEE2E2; color: #B91C1C;">Saída</span>
                                    {{/if}}
                                </td>
                                <td>
                                    <strong style="color: {{#if this.isIncome}}var(--success){{else}}var(--danger){{/if}};">
                                        R$ {{this.amount}}
                                    </strong>
                                </td>
                            </tr>
                        {{else}}
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-muted);">
                                    Nenhuma transação registrada ainda.
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>    
            </div>
        </section>

        <section class="data-card">
            <div class="card-header">
                <h2>Novo Lançamento</h2>
            </div>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">Registre despesas operacionais ou receitas avulsas.</p>
            
            <div id="alert-container"></div>

            <form action="/dashboard/finance/create" method="post">
                
                <div class="form-group">
                    <label>Tipo de Lançamento</label>
                    <select name="type" class="form-input" required>
                        <option value="income">Entrada (Receita)</option>
                        <option value="expense">Saída (Despesa)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Descrição</label>
                    <input type="text" name="description" placeholder="Ex: Conta de Luz, Venda Externa..." class="form-input" required>
                </div>

                <div class="form-group">
                    <label>Categoria</label>
                    <input type="text" name="category" placeholder="Ex: Contas Fixas, Serviços..." class="form-input" required>
                </div>

                <div class="form-group">
                    <label>Valor (R$)</label>
                    <input type="number" step="0.01" name="amount" placeholder="0.00" class="form-input" required>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Salvar Transação</button>
            </form>
        </section>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labelsEntradas = {{{ labelsEntradas }}};
    const dadosEntradas = {{{ dadosEntradas }}};
    
    const labelsSaidas = {{{ labelsSaidas }}};
    const dadosSaidas = {{{ dadosSaidas }}};
    
    const totalEntradas = {{ totalEntradas }};
    const totalSaidas = {{ totalSaidas }};

    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } }
        }
    };

    // 1. Gráfico de Entradas (Receitas Dinâmicas)
    new Chart(document.getElementById('chartEntradas'), {
        type: 'doughnut',
        data: {
            labels: labelsEntradas.length > 0 ? labelsEntradas : ['Sem Dados'],
            datasets: [{
                data: dadosEntradas.length > 0 ? dadosEntradas : [1], // Se não tiver nada, mostra 1 pedaço cinza
                backgroundColor: dadosEntradas.length > 0 ? ['#10B981', '#34D399', '#A7F3D0', '#059669', '#6EE7B7'] : ['#E2E8F0'],
                borderWidth: 0
            }]
        },
        options: chartOptions
    });

    // 2. Gráfico de Saídas (Despesas Dinâmicas)
    new Chart(document.getElementById('chartSaidas'), {
        type: 'doughnut',
        data: {
            labels: labelsSaidas.length > 0 ? labelsSaidas : ['Sem Dados'],
            datasets: [{
                data: dadosSaidas.length > 0 ? dadosSaidas : [1],
                backgroundColor: dadosSaidas.length > 0 ? ['#EF4444', '#F87171', '#FECACA', '#B91C1C', '#FCA5A5'] : ['#E2E8F0'],
                borderWidth: 0
            }]
        },
        options: chartOptions
    });

    // 3. Gráfico Resumo (Entradas x Saídas Dinâmico)
    new Chart(document.getElementById('chartResumo'), {
        type: 'pie',
        data: {
            labels: ['Entradas', 'Saídas'],
            datasets: [{
                data: (totalEntradas === 0 && totalSaidas === 0) ? [1] : [totalEntradas, totalSaidas],
                backgroundColor: (totalEntradas === 0 && totalSaidas === 0) ? ['#E2E8F0'] : ['#0A57E8', '#0D244F'],
                borderWidth: 0
            }]
        },
        options: chartOptions
    });
</script>

 <script>
    const urlParams = new URLSearchParams(window.location.search);
    const alertContainer = document.getElementById('alert-container');

    if (urlParams.get('sucess') === 'create') {
        alertContainer.innerHTML = `
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                <svg width="20" height="20" fill="currentColor" class="bi me-2" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
                <div>Lançamento Cadastrado Com Sucesso!</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>`;
    } 
</script>