<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-slate-50">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StoreHost - Gestão Inteligente</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: '#6366f1'
            }
          }
        }
      };
      document.addEventListener('DOMContentLoaded', () => {
        if (window.lucide) window.lucide.createIcons();
      });
    </script>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <div class="min-h-screen flex bg-slate-50">
      
      <!-- SIDEBAR -->
      <aside class="sticky top-0 h-screen w-64 shrink-0 border-r border-slate-200 hidden lg:flex flex-col bg-white">
        <div class="flex items-center gap-2.5 px-5 h-16 border-b border-slate-200">
          <div class="h-8 w-8 rounded-lg bg-indigo-600 grid place-items-center text-white shadow-lg shadow-indigo-600/20">
            <i data-lucide="layout-dashboard" class="h-5 w-5"></i>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-bold truncate text-slate-900">{{#if storeName}}{{storeName}}{{else}}StoreHost{{/if}}</div>
            <div class="text-[10px] uppercase tracking-[0.25em] text-slate-400 font-semibold">Gestão de loja</div>
          </div>
        </div>

        <nav class="flex-1 overflow-y-auto p-3 flex flex-col gap-0.5">
          <a href="/dashboard" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="layout-dashboard" class="h-4 w-4"></i>
            <span class="truncate">Visão geral</span>
          </a>
          <a href="/dashboard/product" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="package" class="h-4 w-4"></i>
            <span class="truncate">Produtos</span>
          </a>
          <a href="/dashboard/stock" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="boxes" class="h-4 w-4"></i>
            <span class="truncate">Estoque</span>
          </a>
          <a href="/dashboard/sales" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="shopping-cart" class="h-4 w-4"></i>
            <span class="truncate">Vendas / PDV</span>
          </a>
          <a href="/dashboard/employee" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="users" class="h-4 w-4"></i>
            <span class="truncate">Equipe</span>
          </a>
          <a href="/dashboard/finance" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="wallet" class="h-4 w-4"></i>
            <span class="truncate">Financeiro</span>
          </a>
          <a href="/dashboard/scheduling" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="calendar-days" class="h-4 w-4"></i>
            <span class="truncate">Agendamentos</span>
          </a>
          <a href="/dashboard/reports" data-nav-link class="group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-all duration-200 text-slate-600">
            <i data-lucide="file-bar-chart" class="h-4 w-4"></i>
            <span class="truncate">Relatórios</span>
          </a>
        </nav>

        <div class="p-3 border-t border-slate-200 space-y-1">
          <a href="/logout" class="w-full flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-rose-600 hover:bg-rose-50 transition-colors font-semibold">
            <i data-lucide="log-out" class="h-4 w-4"></i> Sair do sistema
          </a>
        </div>
      </aside>

      <!-- CONTENT -->
      <div class="flex-1 flex flex-col min-w-0">
        <header class="sticky top-0 z-30 h-16 border-b border-slate-200 bg-white/80 backdrop-blur-xl flex items-center gap-3 px-6">
          <div class="flex-1 flex items-center gap-2 max-w-md rounded-lg border border-slate-200 bg-slate-50 px-3 h-9">
            <i data-lucide="search" class="h-4 w-4 text-slate-400"></i>
            <input class="flex-1 bg-transparent outline-none text-sm placeholder:text-slate-400 text-slate-800" placeholder="Buscar produtos, vendas…" />
          </div>

          <div class="hidden sm:flex items-center gap-2.5 pl-3 border-l border-slate-200 h-9">
            <div class="h-8 w-8 rounded-full bg-indigo-600 grid place-items-center text-white text-xs font-bold">{{userInitials}}</div>
            <div class="text-left">
              <div class="text-xs font-bold text-slate-900">{{userName}}</div>
            </div>
          </div>

          <a href="/logout" class="h-9 w-9 grid place-items-center rounded-lg border border-slate-200 bg-white hover:bg-rose-50 text-slate-400 hover:text-rose-600 transition-colors" title="Sair">
            <i data-lucide="log-out" class="h-4 w-4"></i>
          </a>
        </header>

        <main class="flex-1 p-6 lg:p-8 max-w-[1600px] w-full mx-auto">
          {{{body}}}
        </main>
      </div>
    </div>

    <script>
      // Lógica simples para ativar menu e modais
      document.addEventListener('DOMContentLoaded', () => {
        const navLinks = document.querySelectorAll('[data-nav-link]');
        const currentPath = window.location.pathname;
        navLinks.forEach(link => {
          if (link.getAttribute('href') === currentPath) {
            link.classList.add('bg-indigo-50', 'text-indigo-600', 'font-bold');
          }
        });
      });
    </script>
  </body>
</html>