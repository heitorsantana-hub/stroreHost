<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StoreHost | Dashboard Premium</title>
    <link rel="shortcut icon" href="/image.ico" type="image/x-icon">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    
    <!-- Sidebar Desktop -->
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">
            <i class="bi bi-box-fill text-primary me-2"></i> Store<span>Host</span>
        </a>
        
        <ul class="nav-list mt-4">
            <li class="nav-item">
                <a href="/dashboard" class="nav-link {{#if activeDashboard}}active{{/if}}">
                    <i class="bi bi-speedometer2"></i> Visão Geral
                </a>
            </li>
            <li class="nav-item">
                <a href="/dashboard/product" class="nav-link {{#if activeProduct}}active{{/if}}">
                    <i class="bi bi-box-seam"></i> Produtos
                </a>
            </li>
            <li class="nav-item">
                <a href="/dashboard/stock" class="nav-link {{#if activeStock}}active{{/if}}">
                    <i class="bi bi-layers"></i> Estoque
                </a>
            </li>
            <li class="nav-item">
                <a href="/dashboard/sales" class="nav-link {{#if activeSales}}active{{/if}}">
                    <i class="bi bi-cart3"></i> Vendas
                </a>
            </li>
            <li class="nav-item">
                <a href="/dashboard/employee" class="nav-link {{#if activeEmployee}}active{{/if}}">
                    <i class="bi bi-people"></i> Equipe
                </a>
            </li>
            <li class="nav-item">
                <a href="/dashboard/finance" class="nav-link {{#if activeFinance}}active{{/if}}">
                    <i class="bi bi-wallet2"></i> Financeiro
                </a>
            </li>
            <li class="nav-item">
                <a href="/dashboard/scheduling" class="nav-link {{#if activeScheduling}}active{{/if}}">
                    <i class="bi bi-calendar3"></i> Agendamentos
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <a href="/login" class="nav-link logout-link">
                <i class="bi bi-box-arrow-right"></i> Terminar Sessão
            </a>
        </div>
    </aside>

    <!-- Mobile Bottom Navigation -->
    <nav class="mobile-nav">
        <a href="/dashboard" class="mobile-nav-item {{#if activeDashboard}}active{{/if}}">
            <i class="bi bi-speedometer2"></i>
            <span>Início</span>
        </a>
        <a href="/dashboard/product" class="mobile-nav-item {{#if activeProduct}}active{{/if}}">
            <i class="bi bi-box-seam"></i>
            <span>Produtos</span>
        </a>
        <a href="/dashboard/stock" class="mobile-nav-item {{#if activeStock}}active{{/if}}">
            <i class="bi bi-layers"></i>
            <span>Estoque</span>
        </a>
        <a href="/dashboard/sales" class="mobile-nav-item {{#if activeSales}}active{{/if}}">
            <i class="bi bi-cart3"></i>
            <span>Vendas</span>
        </a>
        <a href="/dashboard/finance" class="mobile-nav-item {{#if activeFinance}}active{{/if}}">
            <i class="bi bi-wallet2"></i>
            <span>Finanças</span>
        </a>
        <a href="/dashboard/scheduling" class="mobile-nav-item {{#if activeScheduling}}active{{/if}}">
            <i class="bi bi-calendar3"></i>
            <span>Agenda</span>
        </a>
    </nav>

    <main class="main-content">
        <header class="top-bar">
            <div class="search-box">
                <i class="bi bi-search text-muted"></i>
                <input type="text" placeholder="Pesquisar transações, produtos...">
            </div>

            <div class="user-nav">
                <button class="icon-btn">
                    <i class="bi bi-bell"></i>
                    <span class="notification-dot"></span>
                </button>

                <div class="user-profile">
                    <div class="user-name text-end d-none d-md-flex">
                        <span class="store-name-text">{{storeName}}</span>
                        <span class="user-role-text">Administrador</span>
                    </div>
                    <div class="avatar shadow-sm">
                        <i class="bi bi-person-fill"></i>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-body">
            {{{body}}}
        </div>
    </main>
<style>
  :root {
    --chat--color-primary: #0d6efd !important; 
    --chat--color-primary-shade-50: #0a58ca !important;
    --chat--color-primary-shade-100: #084298 !important;
    --chat--color-secondary: #0d6efd !important;
  }
</style>

<link href="https://cdn.jsdelivr.net/npm/@n8n/chat/dist/style.css" rel="stylesheet" />
<script type="module">
  import { createChat } from 'https://cdn.jsdelivr.net/npm/@n8n/chat/dist/chat.bundle.es.js';

  createChat({
    webhookUrl: 'https://edu0777.app.n8n.cloud/webhook/a0d8eb84-d490-4c8c-9f60-d6818d5d9ccd/chat',
    
    initialMessages: [
      'Olá! 👋',
      'Eu sou a Inteligência Artificial do StoreHost. Como posso ajudar com suas lojas hoje?'
    ],
    
    
    i18n: {
      en: {
        title: 'Assistente StoreHost',
        subtitle: 'Pronto para ajudar com seu negócio.',
        getStarted: 'Nova conversa',
        inputPlaceholder: 'Digite sua pergunta...',
      },
      'pt-BR': {
        title: 'Assistente StoreHost',
        subtitle: 'Pronto para ajudar com seu negócio 24/7.',
        getStarted: 'Nova conversa',
        inputPlaceholder: 'Digite sua pergunta...',
      },
      pt: {
        title: 'Assistente StoreHost',
        subtitle: 'Pronto para ajudar com seu negócio 24/7.',
        getStarted: 'Nova conversa',
        inputPlaceholder: 'Digite sua pergunta...',
      }
    }
  });

</script>

</body>
</html>