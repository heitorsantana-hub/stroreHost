<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StoreHost | Dashboard Premium</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">
   
</head>
<body>
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">Store<span>Host</span></a>
        
        <nav class="nav-list">
            <li class="nav-item"><a href="/dashboard" class="nav-link active">Painel Geral</a></li>
            <li class="nav-item"><a href="/dashboard/product" class="nav-link">Produtos</a></li>
            <li class="nav-item"><a href="/dashboard/stock" class="nav-link">Estoque</a></li>
            <li class="nav-item"><a href="/dashboard/employee" class="nav-link">Equipes</a></li>
            <li class="nav-item"><a href="/dashboard/sales" class="nav-link">Vendas</a></li>
            <li class="nav-item"><a href="/dashboard/finance" class="nav-link">Financeiro</a></li>
        </nav>

        <div class="sidebar-footer">
            <a href="/login" class="nav-link">Terminar Sessão</a>
        </div>
    </aside>

    <nav class="mobile-nav">
        <a href="/dashboard" class="mobile-nav-item active">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            <span>Início</span>
        </a>
        <a href="/dashboard/product" class="mobile-nav-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            <span>Produtos</span>
        </a>
        <a href="/dashboard/sales" class="mobile-nav-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <span>Vendas</span>
        </a>
        <a href="/dashboard/finance" class="mobile-nav-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>Finanças</span>
        </a>
        <a href="/login" class="mobile-nav-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            <span>Sair</span>
        </a>
    </nav>

    <main class="main-content">
        <header class="top-bar">
            <div class="user-nav">
                <div class="user-profile">
                    <div class="avatar">AD</div>
                    <div class="user-name">
                        <p style="font-weight: 700; font-size: 0.9rem;">{{storeName}}</p>
                        <p style="font-size: 0.75rem; color: var(--text-muted);">Administrador</p>
                    </div>
                </div>
            </div>
        </header> 

        <div class="content-body">
            {{{body}}}
        </div>
    </main>
</body>
</html>



<script>
    const openBtn = document.getElementById('openSidebar');
    const sidebar = document.querySelector('.sidebar');
    const overlay = document.getElementById('sidebarOverlay');

    function toggleMenu() {
        sidebar.classList.toggle('active');
        overlay.classList.toggle('active');
    }

    openBtn.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);
</script>