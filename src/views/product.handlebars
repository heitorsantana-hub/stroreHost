<div class="content-body">
        
        <section class="welcome-sec">
            <h1>Catálogo de Produtos</h1>
            <p>Gerencie o estoque e adicione novos itens à loja.</p>
        </section>
        
        <div class="main-grid">
            
            <section class="data-card">
    <div class="card-header">
        <h2>Produtos Registrados</h2>
    </div>
    
    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Produto</th>
                    <th>Categoria</th>
                    <th>Preço</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                {{#each produtos}}
                <tr>
                    <td><span class="badge-status status-active">Ativo</span></td>
                    
                    <td>
                        <strong>{{this.name}}</strong><br>
                        <small class="text-muted" style="font-size: 0.7rem;">ID: {{this._id}}</small>
                    </td>
                    
                    <td><span class="text-muted">{{this.category}}</span></td>
                    
                    <td><strong>R$ {{this.price}}</strong></td>
                    
                    <td>
                        <div class="d-flex justify-content-center align-items-center gap-2">
                            
                            <button class="btn btn-outline btn-sm" 
                                data-bs-toggle="modal" 
                                data-bs-target="#viewModal"
                                data-id="{{this._id}}"
                                data-name="{{this.name}}"
                                data-image="{{this.image_url}}"
                                data-category="{{this.category}}"
                                data-description="{{this.description}}"
                                data-quantity="{{this.current_stock}}"
                                data-price="{{this.price}}"
                                data-stock="{{this.current_stock}}">
                                <i class="bi bi-eye"></i> Ver
                            </button>

                            <button class="btn btn-outline btn-sm" 
                                data-bs-toggle="modal" 
                                data-bs-target="#editModal"
                                data-id="{{this._id}}"
                                data-name="{{this.name}}"
                                data-category="{{this.category}}"
                                data-price="{{this.price}}"
                                data-imagem="{{this.image_url}}"
                                data-description="{{this.description}}">
                                Editar
                            </button>

                            <form action="/dashboard/product/delete" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir?')" class="m-0">
                                <input type="hidden" name="product_id" value="{{this._id}}">
                                <button type="submit" class="btn btn-danger btn-sm">Remover</button>
                            </form>

                        </div>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">
                        Nenhum produto cadastrado ainda.
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>    
    </div>
</section>

            <section class="data-card">
                <div class="card-header">
                    <h2>Novo Produto</h2>
                </div>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">Adicione uma nova definição de produto.</p>
                
                <div id="alert-container"></div>

                <form action="/dashboard/products/create" method="post" enctype="multipart/form-data">


                    <div class="form-group">
                        <label>Nome do Produto</label>
                        <input type="text" name="name" placeholder="Ex: Tênis de Corrida" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Categoria</label>
                        <input type="text" name="category" placeholder="Nome da categoria" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label>Preço</label>
                        <input type="text" name="price" placeholder="Valor do preço" class="form-input" required>
                    </div>

                    <div class="form-group">
                        <label>Imagem do Produto</label>
                        <input type="file" name="image" class="form-input" accept="image/*">
                    </div>

                    <div class="form-group">
                        <label>Descrição</label>
                        <textarea name="description" class="form-input" placeholder="Detalhes do produto..." style="height: 100px; resize: none;"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Registrar Produto</button>
                </form>
            </section>

        </div>
    </div>

    <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editForm" method="POST" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Editar Produto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome do Produto</label>
                        <input type="text" name="name" id="edit-name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Categoria</label>
                        <input type="text" name="category" id="edit-category" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Preço</label>
                        <input type="text" name="price" id="edit-price" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nova Imagem (Opcional)</label>
                        <input type="file" name="image" id="edit-image" class="form-input" accept="image/*">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="viewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalhes do Produto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="fw-bold">Nome:</label>
                    <span id="view-name"></span>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Categoria:</label>
                    <span id="view-category"></span>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Preço:</label>
                    <span id="view-price"></span>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Descrição:</label>
                    <p id="view-description" class="text-muted"></p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Quantidade:</label>
                    <p id="view-quantity" class="text-muted"></p>
                </div>
               <div class="mb-3 text-center">
                    <label class="fw-bold d-block mb-2">Imagem do Produto:</label>
                    <img id="view-image" 
                    src="" 
                    alt="Produto" 
                    class="img-fluid rounded shadow-sm d-block mx-auto" 
                    style="max-height: 250px; object-fit: cover;">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>


     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('sucess') === 'create') {
            const alertContainer = document.getElementById('alert-container');
            alertContainer.innerHTML = `
                <div class="alert alert-success d-flex align-items-center" role="alert">
                <svg width="20" height="20" fill="currentColor" class="bi flex-shrink-0 me-2" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                    <div style="font-size: 0.9rem;">Produto Cadastrado Com Sucesso!</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
        }
        else if (urlParams.get('sucess') === 'update') {
            const alertContainer = document.getElementById('alert-container');
            alertContainer.innerHTML = `
                <div class="alert alert-success d-flex align-items-center" role="alert">
                <svg width="20" height="20" fill="currentColor" class="bi flex-shrink-0 me-2" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                    <div style="font-size: 0.9rem;">Produto Atualizado Com Sucesso!</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
        }

        const editModal = document.getElementById('editModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget; // Botão que foi clicado
                
                // Pega os dados que guardamos no botão
                const id = button.getAttribute('data-id');
                const name = button.getAttribute('data-name');
                const category = button.getAttribute('data-category');
                const price = button.getAttribute('data-price');
                const image_url = button.getAttribute('data-imagem');

                // Preenche os inputs do Modal
                editModal.querySelector('#edit-name').value = name;
                editModal.querySelector('#edit-category').value = category;
                editModal.querySelector('#edit-price').value = price;
                
                // Define para onde o formulário será enviado
                editModal.querySelector('#editForm').action = `/dashboard/product/update/${id}`;
            });
        }

        const viewModal = document.getElementById('viewModal');

        if (viewModal) {
        viewModal.addEventListener('show.bs.modal', event => {
            // 1. Identifica o botão que abriu o modal
            const btn = event.relatedTarget;
            console.log("Modal aberto pelo botão do produto ID:", btn.getAttribute('data-id'));

            // 2. Extrai os dados da "mochila" (data-attributes)
            const name = btn.getAttribute('data-name');
            const category = btn.getAttribute('data-category');
            const price = btn.getAttribute('data-price');
            const description = btn.getAttribute('data-description');
            const quantity = btn.getAttribute('data-quantity');
            const image = btn.getAttribute('data-image');

            // 3. Preenche os campos de TEXTO (usando textContent)
            viewModal.querySelector('#view-name').textContent = name || "Não informado";
            viewModal.querySelector('#view-category').textContent = category || "Sem categoria";
            viewModal.querySelector('#view-price').textContent = price ? `R$ ${price}` : "Consulte";
            viewModal.querySelector('#view-quantity').textContent = quantity || "Sem quantidade";
            viewModal.querySelector('#view-description').textContent = description || "Nenhuma descrição disponível.";

            // 4. Trata a IMAGEM (usando o atributo .src)
            const imgElement = viewModal.querySelector('#view-image');
            if (image && image !== "") {
                imgElement.src = image;
                imgElement.style.display = "block"; // Garante que ela apareça
            } else {
                imgElement.src = "https://placehold.co/400x300?text=Produto+Sem+Foto";
            }
        });
    }
    </script>