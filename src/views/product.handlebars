<div class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Catálogo de produtos</h1>
      <p class="mt-1 text-sm text-slate-500 max-w-2xl">
        Gerencie todos os itens da sua loja em um só lugar.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <button onclick="openModal('create-product-modal')" class="h-9 px-4 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-indigo-500 shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all inline-flex items-center gap-2">
        <i data-lucide="plus" class="h-4 w-4"></i>
        Novo produto
      </button>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    <div class="p-4 border-b border-slate-200 flex items-center justify-between gap-2">
      <div class="flex-1 flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 h-9 px-3 max-w-md focus-within:border-indigo-500 transition-colors">
        <i data-lucide="search" class="h-4 w-4 text-slate-400"></i>
        <input placeholder="Buscar por nome ou SKU…" class="flex-1 bg-transparent outline-none text-sm text-slate-900 placeholder:text-slate-400" />
      </div>
      <div class="text-xs font-bold text-slate-400">
        {{produtos.length}} produtos
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400 bg-slate-50 border-b border-slate-200">
            <th class="text-left font-bold px-4 py-3.5">Produto</th>
            <th class="text-left font-bold px-4 py-3.5">SKU / Cód.</th>
            <th class="text-left font-bold px-4 py-3.5">Categoria</th>
            <th class="text-right font-bold px-4 py-3.5">Preço</th>
            <th class="text-right font-bold px-4 py-3.5">Estoque</th>
            <th class="text-left font-bold px-4 py-3.5">Status</th>
            <th class="text-right font-bold px-4 py-3.5">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          
          {{#each produtos}}
          <tr class="hover:bg-slate-50/60 transition-colors">
            <td class="px-4 py-3.5">
              <div class="flex items-center gap-3">
                <div class="h-9 w-9 rounded-lg grid place-items-center bg-indigo-50 text-indigo-600">
                  <i data-lucide="package" class="h-4 w-4"></i>
                </div>
                <span class="font-bold text-slate-800">{{this.name}}</span>
              </div>
            </td>
            <td class="px-4 py-3.5 text-slate-500 font-mono text-xs">{{#if this.barcode}}{{this.barcode}}{{else}}N/A{{/if}}</td>
            <td class="px-4 py-3.5 text-slate-500 font-medium">{{this.category}}</td>
            <td class="px-4 py-3.5 text-right font-bold tabular-nums text-slate-900">R$ {{this.price}}</td>
            <td class="px-4 py-3.5 text-right font-bold tabular-nums {{#if this.current_stock}}text-slate-700{{else}}text-rose-600{{/if}}">
              {{this.current_stock}}
            </td>
            <td class="px-4 py-3.5">
              {{#if this.current_stock}}
                <span class="inline-flex items-center rounded-full bg-emerald-50 border border-emerald-200 px-2.5 py-0.5 text-xs font-bold text-emerald-700">Em Estoque</span>
              {{else}}
                <span class="inline-flex items-center rounded-full bg-rose-50 border border-rose-200 px-2.5 py-0.5 text-xs font-bold text-rose-700">Esgotado</span>
              {{/if}}
            </td>
            <td class="px-4 py-3.5 text-right">
              <div class="flex items-center justify-end gap-1">
                <button 
                  onclick="openViewModal('{{this.name}}', '{{this.image_url}}', '{{this.price}}', '{{this.category}}', '{{this.current_stock}}', '{{this.description}}', '{{this.barcode}}')" 
                  class="h-8 w-8 rounded-md grid place-items-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors" title="Visualizar">
                  <i data-lucide="eye" class="h-4 w-4"></i>
                </button>
                <button 
                  onclick="openEditModal('{{this._id}}', '{{this.name}}', '{{this.category}}', '{{this.price}}', '{{this.cost_price}}', '{{this.barcode}}', '{{this.min_stock}}', '{{this.max_stock}}', '{{this.unit_of_measure}}', '{{this.description}}', '{{this.tags}}')" 
                  class="h-8 w-8 rounded-md grid place-items-center text-slate-400 hover:text-amber-600 hover:bg-amber-50 transition-colors" title="Editar">
                  <i data-lucide="edit" class="h-4 w-4"></i>
                </button>
                <form action="/dashboard/product/delete" method="POST" class="inline-block m-0" onsubmit="return confirm('Tem certeza que deseja excluir o produto {{this.name}}?');">
                  <input type="hidden" name="product_id" value="{{this._id}}">
                  <button type="submit" class="h-8 w-8 rounded-md grid place-items-center text-slate-400 hover:text-rose-600 hover:bg-rose-50 transition-colors" title="Excluir">
                    <i data-lucide="trash-2" class="h-4 w-4"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="7" class="px-4 py-12 text-center text-slate-500">
              <div class="flex flex-col items-center justify-center">
                <i data-lucide="package-x" class="h-10 w-10 text-slate-300 mb-3"></i>
                <p class="font-bold text-slate-600 text-base">Nenhum produto cadastrado</p>
                <p class="text-sm mt-1">Clique em "Novo produto" para começar a organizar o seu catálogo.</p>
              </div>
            </td>
          </tr>
          {{/each}}
          
        </tbody>
      </table>
    </div>
  </div>
</div>


<div id="create-product-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-3xl items-center justify-center">
    <div class="w-full rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl overflow-y-auto max-h-[90vh]">
      <div class="flex items-start justify-between gap-3 mb-6">
        <div>
          <h3 class="text-xl font-bold text-slate-900">Adicionar Novo Produto</h3>
          <p class="mt-1 text-sm text-slate-500">Preencha os dados básicos, valores e a imagem do item.</p>
        </div>
        <button type="button" onclick="closeModal('create-product-modal')" class="h-9 w-9 rounded-lg border border-slate-200 bg-slate-50 text-slate-500 hover:bg-slate-100 transition-colors flex items-center justify-center">
          <i data-lucide="x" class="h-4 w-4"></i>
        </button>
      </div>

      <form action="/dashboard/products/create" method="POST" enctype="multipart/form-data" class="space-y-4">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Nome do Produto *</label>
            <input name="name" type="text" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors" placeholder="Ex: Tênis Nike Air Max" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Categoria *</label>
            <input name="category" type="text" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="Ex: Calçados" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Código de Barras/SKU</label>
            <input name="barcode" type="text" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="Deixe em branco para gerar auto" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Preço de Custo (R$) *</label>
            <input name="cost_price" type="number" step="0.01" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="0.00" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Preço de Venda (R$) *</label>
            <input name="price" type="number" step="0.01" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="0.00" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Estoque Mínimo</label>
            <input name="min_stock" type="number" value="5" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Máximo</label>
              <input name="max_stock" type="number" value="100" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
            </div>
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Unidade</label>
              <select name="unit_of_measure" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white">
                <option value="UN">UN</option>
                <option value="KG">KG</option>
                <option value="LT">LT</option>
                <option value="CX">CX</option>
              </select>
            </div>
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Tags (Separar por vírgula)</label>
            <input name="tags" type="text" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" placeholder="Ex: promoção, vegano, inverno" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Foto do Produto</label>
            <input name="image" type="file" accept="image/*" class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
          </div>

          <div class="md:col-span-2">
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Descrição</label>
            <textarea name="description" rows="2" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors" placeholder="Detalhes do produto..."></textarea>
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-end gap-3 pt-4 border-t border-slate-100 mt-6">
          <button type="button" onclick="closeModal('create-product-modal')" class="h-10 rounded-lg border border-slate-200 bg-slate-50 px-4 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors">Cancelar</button>
          <button type="submit" class="h-10 rounded-lg bg-gradient-to-r from-indigo-600 to-indigo-500 px-6 text-sm font-bold text-white shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all flex items-center gap-2">
            <i data-lucide="check" class="h-4 w-4"></i> Salvar Produto
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="edit-product-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-3xl items-center justify-center">
    <div class="w-full rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl overflow-y-auto max-h-[90vh]">
      <div class="flex items-start justify-between gap-3 mb-6">
        <div>
          <h3 class="text-xl font-bold text-slate-900">Editar Produto</h3>
          <p class="mt-1 text-sm text-slate-500">Atualize as informações ou troque a foto.</p>
        </div>
        <button type="button" onclick="closeModal('edit-product-modal')" class="h-9 w-9 rounded-lg border border-slate-200 bg-slate-50 text-slate-500 hover:bg-slate-100 transition-colors flex items-center justify-center">
          <i data-lucide="x" class="h-4 w-4"></i>
        </button>
      </div>

      <form id="edit-product-form" action="" method="POST" enctype="multipart/form-data" class="space-y-4">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Nome do Produto *</label>
            <input id="edit_name" name="name" type="text" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Categoria *</label>
            <input id="edit_category" name="category" type="text" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Código de Barras/SKU</label>
            <input id="edit_barcode" name="barcode" type="text" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Preço de Custo (R$) *</label>
            <input id="edit_cost_price" name="cost_price" type="number" step="0.01" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Preço de Venda (R$) *</label>
            <input id="edit_price" name="price" type="number" step="0.01" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Estoque Mínimo</label>
            <input id="edit_min_stock" name="min_stock" type="number" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Máximo</label>
              <input id="edit_max_stock" name="max_stock" type="number" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
            </div>
            <div>
              <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Unidade</label>
              <select id="edit_unit" name="unit_of_measure" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white">
                <option value="UN">UN</option>
                <option value="KG">KG</option>
                <option value="LT">LT</option>
                <option value="CX">CX</option>
              </select>
            </div>
          </div>

          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Tags</label>
            <input id="edit_tags" name="tags" type="text" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Nova Foto (Opcional)</label>
            <input name="image" type="file" accept="image/*" class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
          </div>

          <div class="md:col-span-2">
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.25em] text-slate-700">Descrição</label>
            <textarea id="edit_description" name="description" rows="2" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors"></textarea>
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-end gap-3 pt-4 border-t border-slate-100 mt-6">
          <button type="button" onclick="closeModal('edit-product-modal')" class="h-10 rounded-lg border border-slate-200 bg-slate-50 px-4 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors">Cancelar</button>
          <button type="submit" class="h-10 rounded-lg bg-gradient-to-r from-amber-500 to-amber-600 px-6 text-sm font-bold text-white shadow-md shadow-amber-600/10 hover:from-amber-600 hover:to-amber-700 transition-all flex items-center gap-2">
            <i data-lucide="save" class="h-4 w-4"></i> Atualizar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="view-product-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-xl items-center justify-center">
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-2xl overflow-hidden">
      <div class="h-64 bg-slate-100 w-full relative border-b border-slate-200 flex items-center justify-center">
        <button type="button" onclick="closeModal('view-product-modal')" class="absolute top-4 right-4 h-9 w-9 rounded-lg bg-white/80 backdrop-blur text-slate-600 hover:bg-white transition-colors flex items-center justify-center shadow-sm">
          <i data-lucide="x" class="h-4 w-4"></i>
        </button>
        <img id="view_image" src="" alt="Produto" class="h-full w-full object-cover hidden">
        <i id="view_no_image" data-lucide="image" class="h-16 w-16 text-slate-300"></i>
      </div>
      
      <div class="p-6">
        <div class="flex items-center gap-2 mb-1">
          <span id="view_category" class="text-[10px] font-bold uppercase tracking-[0.25em] text-indigo-600">Categoria</span>
          <span class="text-slate-300">•</span>
          <span id="view_barcode" class="text-[10px] font-mono text-slate-500">SKU</span>
        </div>
        <h3 id="view_name" class="text-2xl font-bold text-slate-900">Nome do Produto</h3>
        
        <div class="mt-4 flex items-center gap-6">
          <div>
            <p class="text-xs text-slate-500 font-medium">Preço de Venda</p>
            <p id="view_price" class="text-xl font-bold text-slate-900">R$ 0,00</p>
          </div>
          <div class="h-8 w-px bg-slate-200"></div>
          <div>
            <p class="text-xs text-slate-500 font-medium">Estoque Atual</p>
            <p id="view_stock" class="text-xl font-bold text-slate-700">0 un</p>
          </div>
        </div>

        <div class="mt-6">
          <p class="text-sm text-slate-800 leading-relaxed" id="view_desc">Nenhuma descrição informada.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Re-renderiza os ícones caso necessário
  if (window.lucide) window.lucide.createIcons();

  function openModal(id) {
    const modal = document.getElementById(id);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal(id) {
    const modal = document.getElementById(id);
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // Abre o modal de visualização preenchendo os dados
  function openViewModal(name, imageUrl, price, category, stock, description, barcode) {
    document.getElementById('view_name').innerText = name;
    document.getElementById('view_category').innerText = category;
    document.getElementById('view_price').innerText = 'R$ ' + price;
    document.getElementById('view_stock').innerText = stock || '0';
    document.getElementById('view_barcode').innerText = barcode || 'N/A';
    document.getElementById('view_desc').innerText = description || 'Nenhuma descrição detalhada informada.';
    
    const imgEl = document.getElementById('view_image');
    const noImgEl = document.getElementById('view_no_image');
    
    if (imageUrl && imageUrl !== '') {
      imgEl.src = imageUrl;
      imgEl.classList.remove('hidden');
      noImgEl.classList.add('hidden');
    } else {
      imgEl.classList.add('hidden');
      noImgEl.classList.remove('hidden');
    }

    openModal('view-product-modal');
  }

  // Abre o modal de edição e injeta a Rota e os Valores
  function openEditModal(id, name, category, price, cost_price, barcode, min_stock, max_stock, unit, description, tags) {
    // Aponta a ação do formulário para o ID correto do produto
    document.getElementById('edit-product-form').action = '/dashboard/product/update/' + id;
    
    // Preenche os inputs
    document.getElementById('edit_name').value = name;
    document.getElementById('edit_category').value = category;
    document.getElementById('edit_price').value = price;
    document.getElementById('edit_cost_price').value = cost_price || '';
    document.getElementById('edit_barcode').value = barcode || '';
    document.getElementById('edit_min_stock').value = min_stock || '5';
    document.getElementById('edit_max_stock').value = max_stock || '100';
    document.getElementById('edit_description').value = description || '';
    document.getElementById('edit_tags').value = tags || '';
    
    if (unit) document.getElementById('edit_unit').value = unit;

    openModal('edit-product-modal');
  }
</script>