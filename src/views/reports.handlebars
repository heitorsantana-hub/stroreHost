<style>
    /* MÁGICA DO PDF: Estas regras só são aplicadas quando o utilizador clica em Imprimir/Salvar PDF */
    @media print {
        @page { margin: 1cm; size: A4 portrait; }
        body { background-color: #ffffff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        
        /* Esconde a barra lateral, o cabeçalho superior e botões que não devem ir para o PDF */
        .sidebar, .top-header, .btn-no-print, .modal-backdrop { display: none !important; }
        
        /* Ajusta o conteúdo para ocupar 100% da folha */
        .content-body { margin-left: 0 !important; padding: 0 !important; width: 100% !important; }
        
        /* Força a quebra de página a não cortar os cartões ao meio */
        .data-card { page-break-inside: avoid; border: 1px solid #e2e8f0 !important; box-shadow: none !important; }
        
        /* Remove o fundo escuro do texto da IA para economizar tinta/ficar limpo */
        #ai-summary-card { background-color: #f8fafc !important; }
    }
</style>

<div class="content-body" id="printable-report">
    <section class="welcome-sec d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 style="color: var(--secondary); font-weight: 800;">Relatório Executivo Mensal</h1>
            <p class="mb-0 text-muted">Análise de desempenho, fluxo de caixa e inteligência de vendas da loja.</p>
        </div>
        
        <div class="btn-no-print d-flex gap-2">
            <a href="/dashboard/reports/csv" class="btn btn-outline-success fw-semibold shadow-sm">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> Exportar CSV
            </a>
            <button onclick="window.print()" class="btn btn-primary fw-semibold shadow-sm">
                <i class="bi bi-file-earmark-pdf me-1"></i> Salvar como PDF
            </button>
        </div>
    </section>

    <div class="card border-0 shadow-sm mb-4" id="ai-summary-card" style="background-color: var(--primary-light); border-left: 5px solid var(--primary) !important;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3 d-flex align-items-center" style="color: var(--secondary);">
                <i class="bi bi-robot text-primary me-2 fs-4"></i> Resumo Estratégico gerado por IA
            </h5>
            <div id="ai-report-content" style="color: var(--text-main); font-size: 0.95rem; line-height: 1.7;">
                <div class="d-flex align-items-center">
                    <span class="spinner-border spinner-border-sm text-primary me-2" role="status"></span>
                    <span class="text-primary fw-semibold">A inteligência artificial está a ler os dados deste mês para gerar o parecer executivo...</span>
                </div>
            </div>
        </div>
    </div>

    <div class="stats-grid mb-4">
        <div class="stat-card border-0 shadow-sm">
            <div class="stat-header">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.8rem;">Faturamento Comercial</h6>
                    <div class="stat-value text-dark fw-bolder fs-3">R$ {{kpiVendas}}</div>
                </div>
                <div class="stat-icon" style="background-color: #D1FAE5; color: #10B981;">
                    <i class="bi bi-currency-dollar fs-4"></i>
                </div>
            </div>
            <div class="trend text-muted mt-2" style="font-size: 0.8rem;"><i class="bi bi-graph-up-arrow"></i> Total acumulado no período</div>
        </div>

        <div class="stat-card border-0 shadow-sm">
            <div class="stat-header">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.8rem;">Despesas Totais</h6>
                    <div class="stat-value text-dark fw-bolder fs-3">R$ {{kpiDespesas}}</div>
                </div>
                <div class="stat-icon" style="background-color: #FEE2E2; color: #EF4444;">
                    <i class="bi bi-wallet2 fs-4"></i>
                </div>
            </div>
            <div class="trend text-muted mt-2" style="font-size: 0.8rem;"><i class="bi bi-graph-down-arrow"></i> Saídas registadas</div>
        </div>

        <div class="stat-card border-0 shadow-sm">
            <div class="stat-header">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.8rem;">Catálogo Ativo</h6>
                    <div class="stat-value text-dark fw-bolder fs-3">{{kpiProdutos}}</div>
                </div>
                <div class="stat-icon" style="background-color: #DBEAFE; color: #3B82F6;">
                    <i class="bi bi-box-seam fs-4"></i>
                </div>
            </div>
            <div class="trend text-muted mt-2" style="font-size: 0.8rem;"><i class="bi bi-tags"></i> Produtos disponíveis</div>
        </div>

        <div class="stat-card border-0 shadow-sm">
            <div class="stat-header">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.8rem;">Estoque Crítico</h6>
                    <div class="stat-value text-dark fw-bolder fs-3">{{kpiEstoqueBaixo}}</div>
                </div>
                <div class="stat-icon" style="background-color: #FEF3C7; color: #F59E0B;">
                    <i class="bi bi-exclamation-triangle fs-4"></i>
                </div>
            </div>
            <div class="trend text-muted mt-2" style="font-size: 0.8rem;"><i class="bi bi-info-circle"></i> Precisam de reposição</div>
        </div>
    </div>

    <div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="data-card border-0 shadow-sm h-100 p-4">
            <h5 class="fw-bold mb-4" style="color: var(--secondary);">Evolução do Faturamento (Ano)</h5>
            <div style="position: relative; height: 300px; width: 100%;">
                <canvas id="chartFaturamento"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="data-card border-0 shadow-sm h-100 p-4">
            <h5 class="fw-bold mb-4" style="color: var(--secondary);">Receita por Pagamento</h5>
            <div style="position: relative; height: 300px; width: 100%;">
                <canvas id="chartPagamentos"></canvas>
            </div>
        </div>
    </div>
</div>

<span class="d-none" id="dados-pagamento">{{{ faturamentoPagamento }}}</span>

    <div class="row">
        <div class="col-12">
            <section class="data-card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3" style="color: var(--secondary);">Produtos Mais Vendidos (Top 5)</h5>
                <div class="table-container">
                    <table class="custom-table" style="color: var(--text-main);">
                        <thead style="color: var(--text-muted); border-bottom: 2px solid #f1f5f9;">
                            <tr>
                                <th class="py-3">Produto</th>
                                <th class="text-end py-3">Performance de Vendas</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each topProdutos}}
                            <tr>
                                <td class="py-3">
                                    <div class="d-flex align-items-center">
                                        <span class="bg-light rounded p-2 me-3 fs-5">🌟</span>
                                        <strong>{{this._id}}</strong>
                                    </div>
                                </td>
                                <td class="text-end py-3 fw-bold text-success">{{this.totalVendido}} unidades</td>
                            </tr>
                            {{else}}
                            <tr>
                                <td colspan="2" class="text-center py-4 text-muted">Ainda não existem vendas suficientes para o ranking.</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>


    <div class="row mt-4 mb-5">
        <div class="col-12">
            <section class="data-card border-0 shadow-sm p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 border-bottom pb-3">
                    <div>
                        <h5 class="fw-bold mb-1" style="color: var(--secondary);">Auditoria de Caixa Diário</h5>
                        <p class="mb-0 text-muted" style="font-size: 0.85rem;">Consulte o histórico exato de transações de um dia específico.</p>
                    </div>
                    <div class="d-flex gap-2 align-items-center btn-no-print">
                        <input type="date" id="search-date" class="form-control border-primary text-primary fw-semibold shadow-sm" style="max-width: 180px;">
                        <button id="btn-search-sales" class="btn btn-primary fw-semibold shadow-sm px-4">
                            <i class="bi bi-search me-1"></i> Buscar
                        </button>
                    </div>
                </div>

                <div class="table-container">
                    <table class="custom-table" style="color: var(--text-main);">
                        <thead style="color: var(--text-muted); border-bottom: 2px solid #f1f5f9;">
                            <tr>
                                <th class="py-3">Horário</th>
                                <th class="py-3">Produto</th>
                                <th class="py-3 text-center">Forma de Pagamento</th>
                                <th class="py-3 text-center">Quantidade</th>
                                <th class="py-3 text-end">Total da Venda</th>
                            </tr>
                        </thead>
                        <tbody id="daily-sales-results">
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar2-date fs-2 d-block mb-2 opacity-50"></i>
                                    Selecione uma data acima para visualizar as vendas.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    
    // 1. CARREGAMENTO DOS GRÁFICOS (Renderizados perfeitamente no PDF)
    const labelsFaturamento = {{{ labelsFaturamento }}};
    const dadosFaturamento = {{{ dadosFaturamento }}};
    const ctxArea = document.getElementById('chartFaturamento');
    
    if (ctxArea) {
        new Chart(ctxArea, {
            type: 'bar', // Alterado para barras para melhor visualização impressa
            data: {
                labels: labelsFaturamento.length > 0 ? labelsFaturamento : ['Sem Dados'],
                datasets: [{
                    label: 'Faturamento (R$)',
                    data: dadosFaturamento.length > 0 ? dadosFaturamento : [0], 
                    backgroundColor: '#0A57E8',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { grid: { borderDash: [5, 5] }, beginAtZero: true }
                }
            }
        });
    }

    const labelsDespesas = {{{ labelsDespesas }}};
    const dadosDespesas = {{{ dadosDespesas }}};
    const ctxPie = document.getElementById('chartDespesas');
    
    if (ctxPie) {
        const hasData = labelsDespesas.length > 0;
        new Chart(ctxPie, {
            type: 'doughnut',
            data: {
                labels: hasData ? labelsDespesas : ['Sem Despesas'],
                datasets: [{
                    data: hasData ? dadosDespesas : [1],
                    backgroundColor: hasData ? ['#EF4444', '#F59E0B', '#0A57E8', '#10B981', '#8B5CF6'] : ['#E2E8F0'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '70%',
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } }
            }
        });
    }

    // 2. BUSCA DO RESUMO EXECUTIVO DA IA
    try {
        // Aproveitamos a rota que já usou no Cockpit, ou a rota de relatório
        const response = await fetch('/dashboard/ai-report');
        const contentEl = document.getElementById('ai-report-content');
        
        if (response.ok) {
            const data = await response.json();
            // Substitui negritos Markdown por HTML e injeta
            const textoFormatado = data.relatorio.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            contentEl.innerHTML = `<p class="mb-0">${textoFormatado.replace(/\n/g, '<br>')}</p>`;
        } else {
            contentEl.innerHTML = `<p class="mb-0 text-muted">Não foi possível carregar o resumo estratégico neste momento.</p>`;
        }
    } catch (error) {
        document.getElementById('ai-report-content').innerHTML = `<p class="mb-0 text-muted">Aguardando dados para análise.</p>`;
    }
});

// =======================================================
    // GRÁFICO 2: Receita por Pagamento (PIX, Cartão, etc)
    // =======================================================
    const rawDadosPagamento = document.getElementById('dados-pagamento');
    const ctxPagamentos = document.getElementById('chartPagamentos');
    
    if (ctxPagamentos && rawDadosPagamento && rawDadosPagamento.innerText) {
        try {
            // Pega o texto do HTML e converte de volta para código
            const arrPagamentos = JSON.parse(rawDadosPagamento.innerText);
            
            // Separa os nomes (PIX, Cartão) e os Valores Totais
            const labelsPag = arrPagamentos.map(item => item._id || "Não Informado");
            const totaisPag = arrPagamentos.map(item => item.total);

            new Chart(ctxPagamentos, {
                type: 'doughnut',
                data: {
                    labels: labelsPag.length > 0 ? labelsPag : ['Sem Vendas'],
                    datasets: [{
                        data: totaisPag.length > 0 ? totaisPag : [1],
                        // Cores exclusivas para diferenciar os pagamentos
                        backgroundColor: ['#10B981', '#3B82F6', '#F59E0B', '#8B5CF6'], 
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true, 
                    maintainAspectRatio: false, 
                    cutout: '70%',
                    plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } }
                }
            });
        } catch (e) {
            console.error("Erro ao montar gráfico de pagamentos:", e);
        }
    }


    // =======================================================
    // MOTOR DE BUSCA: Vendas Diárias
    // =======================================================
    const btnSearch = document.getElementById('btn-search-sales');
    
    if (btnSearch) {
        btnSearch.addEventListener('click', async () => {
            const dateInput = document.getElementById('search-date').value;
            const tbody = document.getElementById('daily-sales-results');

            if (!dateInput) {
                alert("Por favor, selecione uma data no calendário.");
                return;
            }

            // Estado de carregamento
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="text-center py-5">
                        <span class="spinner-border text-primary mb-2" role="status"></span>
                        <p class="text-muted mb-0 fw-semibold">Procurando registros...</p>
                    </td>
                </tr>`;

            try {
                const response = await fetch(`/api/reports/daily-sales?date=${dateInput}`);
                
                if (response.ok) {
                    const vendas = await response.json();

                    // Se não houver vendas naquele dia
                    if (vendas.length === 0) {
                        tbody.innerHTML = `
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-2 opacity-50"></i>
                                    Nenhuma venda registada nesta data.
                                </td>
                            </tr>`;
                        return;
                    }

                    // Se houver vendas, desenha a tabela
                    tbody.innerHTML = '';
                    vendas.forEach(v => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td class="py-3 text-muted fw-semibold">${v.hora}</td>
                            <td class="py-3 fw-bold">${v.product_name}</td>
                            <td class="py-3 text-center"><span class="badge bg-light text-dark border rounded-pill">${v.payment_method}</span></td>
                            <td class="py-3 text-center">${v.quantity} un.</td>
                            <td class="py-3 text-end fw-bold text-success">R$ ${v.total_price}</td>
                        `;
                        tbody.appendChild(tr);
                    });
                } else {
                    throw new Error("Falha na resposta da API");
                }
            } catch (error) {
                console.error(error);
                tbody.innerHTML = `
                    <tr>
                        <td colspan="5" class="text-center py-4 text-danger fw-semibold">
                            Houve um erro de comunicação com o servidor. Tente novamente.
                        </td>
                    </tr>`;
            }
        });
    }

</script>
