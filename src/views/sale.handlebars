<div class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4 mb-2">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Ponto de Venda (PDV)</h1>
      <p class="mt-1 text-sm text-slate-500 max-w-2xl">
        Registe novas vendas, adicione produtos ao carrinho e faça o fecho da transação.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="lg:col-span-2 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm flex flex-col h-[600px]">
      <div class="flex items-center gap-2 mb-4">
        <div class="flex-1 flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 h-10 px-3 focus-within:border-indigo-500 transition-colors">
          <i data-lucide="search" class="h-4 w-4 text-slate-400"></i>
          <input id="search-product" onkeyup="filterProducts()" placeholder="Buscar produto no catálogo…" class="flex-1 bg-transparent outline-none text-sm text-slate-900 placeholder:text-slate-400" />
        </div>
        <button class="h-10 px-3 rounded-lg border border-slate-200 bg-slate-50 hover:bg-slate-100 transition-colors text-sm font-bold inline-flex items-center gap-1.5 text-slate-700">
          <i data-lucide="scan-line" class="h-4 w-4 text-slate-500"></i>
          Ler código
        </button>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 overflow-y-auto pr-2 pb-2" id="products-grid">
        {{#each produtos}}
          <button onclick="addToCart('{{this._id}}', '{{this.name}}', {{this.price}}, {{this.current_stock}})" 
                  class="product-card text-left rounded-xl border border-slate-200 p-4 hover:border-indigo-600 hover:shadow-md transition-all bg-slate-50/50 hover:bg-white group"
                  data-name="{{this.name}}">
            <div class="h-20 rounded-lg mb-3 flex items-center justify-center overflow-hidden border border-slate-200 shadow-inner group-hover:shadow-md transition-all">
                <img src="{{this.image_url}}" class="h-full w-full object-cover" alt="{{this.name}}"
                    onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name={{this.name}}&background=6366f1&color=ffffff&bold=true&size=256';">
                </div>
            <div class="text-sm font-bold leading-tight text-slate-900 truncate">{{this.name}}</div>
            <div class="mt-1 flex items-center justify-between">
              <div class="text-sm font-bold tabular-nums text-indigo-600">R$ {{this.price}}</div>
              <div class="text-[10px] font-bold px-2 py-0.5 rounded-full {{#if this.current_stock}}bg-emerald-100 text-emerald-700{{else}}bg-rose-100 text-rose-700{{/if}}">
                {{this.current_stock}} un
              </div>
            </div>
          </button>
        {{else}}
          <div class="col-span-full flex flex-col items-center justify-center py-12 text-slate-400">
            <i data-lucide="package-x" class="h-10 w-10 mb-2"></i>
            <p>Nenhum produto cadastrado no catálogo.</p>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white flex flex-col h-[600px] shadow-sm overflow-hidden">
      <div class="p-5 border-b border-slate-200 bg-slate-50/50 flex justify-between items-center">
        <div>
          <h2 class="text-base font-bold text-slate-900">Carrinho</h2>
          <p class="text-xs font-medium text-slate-400" id="cart-count">0 item(s)</p>
        </div>
        <button onclick="clearCart()" class="text-xs font-bold text-rose-600 hover:text-rose-700 flex items-center gap-1">
          <i data-lucide="trash" class="h-3 w-3"></i> Limpar
        </button>
      </div>

      <div class="flex-1 overflow-y-auto">
        <ul id="cart-items" class="divide-y divide-slate-200">
          <li class="p-8 text-center text-slate-400 flex flex-col items-center justify-center h-full">
            <i data-lucide="shopping-cart" class="h-8 w-8 mb-2 opacity-50"></i>
            <span class="text-sm">O carrinho está vazio.</span>
          </li>
        </ul>
      </div>

      <div class="p-5 border-t border-slate-200 bg-slate-50/30 space-y-3">
        <div class="flex items-center justify-between text-base font-bold text-slate-900 pt-1">
          <span>Total</span>
          <span class="tabular-nums text-2xl text-slate-900" id="cart-total">R$ 0.00</span>
        </div>

        <button onclick="openPaymentModal()" id="btn-checkout" disabled class="w-full h-11 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-indigo-500 shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all inline-flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
          <i data-lucide="credit-card" class="h-4 w-4"></i>
          Avançar para Pagamento
        </button>
        <p class="text-[10px] font-medium text-center text-slate-400">
          O stock será abatido automaticamente.
        </p>
      </div>
    </div>
  </div>

  <div class="mt-8 rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-200 flex items-center justify-between bg-slate-50/50">
      <div>
        <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
          <i data-lucide="history" class="h-5 w-5 text-indigo-600"></i> Histórico de Vendas
        </h2>
        <p class="text-xs font-medium text-slate-500 mt-1">Registo das transações concluídas.</p>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400 bg-slate-50 border-b border-slate-200">
            <th class="text-left px-5 py-4">Data da Venda</th>
            <th class="text-left px-5 py-4">Produto Vendido</th>
            <th class="text-center px-5 py-4">Quantidade</th>
            <th class="text-center px-5 py-4">Pagamento</th>
            <th class="text-right px-5 py-4">Total</th>
            <th class="text-right px-5 py-4">Ação</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {{#each vendas}}
          <tr class="hover:bg-slate-50/60 transition-colors">
            <td class="px-5 py-4 text-slate-500 font-medium">{{formatDate this.createdAt}}</td>
            <td class="px-5 py-4 font-bold text-slate-800">{{this.product_name}}</td>
            <td class="px-5 py-4 text-center font-bold text-slate-700">{{this.quantity}} un</td>
            <td class="px-5 py-4 text-center">
              <span class="inline-flex items-center rounded-full bg-slate-100 border border-slate-200 px-2.5 py-0.5 text-xs font-bold text-slate-700">
                {{this.payment_method}}
              </span>
            </td>
            <td class="px-5 py-4 text-right font-bold tabular-nums text-emerald-600">R$ {{this.total_price}}</td>
            <td class="px-5 py-4 text-right">
              <form action="/dashboard/sales/delete" method="POST" onsubmit="return confirm('ATENÇÃO: Deseja estornar esta venda? O valor será registado como saída e o stock devolvido.');" class="m-0 inline-block">
                <input type="hidden" name="sale_id" value="{{this._id}}">
                <button type="submit" class="h-8 w-8 rounded-md grid place-items-center text-slate-400 hover:text-rose-600 hover:bg-rose-50 transition-colors" title="Estornar Venda">
                  <i data-lucide="rotate-ccw" class="h-4 w-4"></i>
                </button>
              </form>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="6" class="px-5 py-8 text-center text-slate-400">
              Nenhuma venda registada até o momento.
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>

<div id="payment-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-md items-center justify-center">
    
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-2xl flex flex-col max-h-[90vh] overflow-hidden">
      
      <div class="p-6 border-b border-slate-200 bg-slate-50 flex items-center justify-between shrink-0">
        <h3 class="text-lg font-bold text-slate-900">Finalizar Transação</h3>
        <button type="button" onclick="closePaymentModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
          <i data-lucide="x" class="h-5 w-5"></i>
        </button>
      </div>
      
      <div class="p-6 space-y-5 overflow-y-auto flex-1">
        <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4 text-center">
          <p class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-1">Total a Pagar</p>
          <p class="text-3xl font-bold text-indigo-700" id="modal-total">R$ 0.00</p>
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Forma de Pagamento</label>
          <select id="payment_method" class="h-12 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm font-bold text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors">
            <option value="Pix">Pix</option>
            <option value="Cartão de Crédito">Cartão de Crédito</option>
            <option value="Cartão de Débito">Cartão de Débito</option>
            <option value="Dinheiro">Dinheiro</option>
          </select>
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Notas Adicionais (Opcional)</label>
          <input type="text" id="sale_notes" placeholder="Ex: Cliente solicitou fatura..." class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors">
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-emerald-600">WhatsApp do Cliente (Opcional)</label>
          <div class="relative rounded-xl shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-emerald-500">
              <i data-lucide="message-circle" class="h-4 w-4"></i>
            </div>
            <input type="text" id="customer_whatsapp" placeholder="Ex: 5571999999999" class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-colors">
          </div>
          <p class="text-[10px] text-slate-500 mt-1">Insira o código do país + DDD + número (Apenas números).</p>
        </div>
      </div>

      <div class="p-6 border-t border-slate-100 bg-white shrink-0">
        <button onclick="processCheckout()" id="btn-confirm-sale" class="w-full h-12 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-emerald-500 to-emerald-600 shadow-md shadow-emerald-500/20 hover:from-emerald-600 hover:to-emerald-700 transition-all flex items-center justify-center gap-2">
          <i data-lucide="check-circle" class="h-5 w-5"></i> Confirmar Recebimento
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  let cart = [];

  // Função para pesquisar produtos na grelha
  function filterProducts() {
    const input = document.getElementById('search-product').value.toLowerCase();
    const cards = document.querySelectorAll('.product-card');
    
    cards.forEach(card => {
      const name = card.getAttribute('data-name').toLowerCase();
      card.style.display = name.includes(input) ? 'block' : 'none';
    });
  }

  // Adicionar produto ao carrinho
  function addToCart(id, name, price, stock) {
    if (stock <= 0) {
      alert("Este produto está esgotado!");
      return;
    }

    const existingItem = cart.find(item => item.id === id);
    if (existingItem) {
      if (existingItem.quantity >= stock) {
        alert("Quantidade máxima em stock atingida!");
        return;
      }
      existingItem.quantity += 1;
    } else {
      cart.push({ id, name, price: parseFloat(price), quantity: 1, maxStock: stock });
    }
    renderCart();
  }

  // Alterar a quantidade (+ ou -)
  function updateQuantity(id, delta) {
    const item = cart.find(i => i.id === id);
    if (item) {
      const newQuantity = item.quantity + delta;
      if (newQuantity <= 0) {
        cart = cart.filter(i => i.id !== id);
      } else if (newQuantity > item.maxStock) {
        alert("Quantidade máxima em stock atingida!");
      } else {
        item.quantity = newQuantity;
      }
      renderCart();
    }
  }

  // Remover produto do carrinho
  function removeFromCart(id) {
    cart = cart.filter(item => item.id !== id);
    renderCart();
  }

  // Limpar todo o carrinho
  function clearCart() {
    cart = [];
    renderCart();
  }

  // Atualizar a interface do carrinho
  function renderCart() {
    const cartList = document.getElementById('cart-items');
    const cartCount = document.getElementById('cart-count');
    const cartTotal = document.getElementById('cart-total');
    const btnCheckout = document.getElementById('btn-checkout');

    cartList.innerHTML = '';
    let total = 0;
    let totalItems = 0;

    if (cart.length === 0) {
      cartList.innerHTML = `
        <li class="p-8 text-center text-slate-400 flex flex-col items-center justify-center h-full">
          <i data-lucide="shopping-cart" class="h-8 w-8 mb-2 opacity-50"></i>
          <span class="text-sm">O carrinho está vazio.</span>
        </li>`;
      btnCheckout.disabled = true;
    } else {
      btnCheckout.disabled = false;
      cart.forEach(item => {
        total += item.price * item.quantity;
        totalItems += item.quantity;

        const li = document.createElement('li');
        li.className = "p-4 flex items-center gap-3 hover:bg-slate-50/40 transition-colors";
        li.innerHTML = `
          <div class="flex-1 min-w-0">
            <div class="text-sm font-bold truncate text-slate-800">${item.name}</div>
            <div class="text-xs font-medium text-slate-400">R$ ${item.price.toFixed(2)} un</div>
          </div>
          <div class="flex items-center gap-1">
            <button onclick="updateQuantity('${item.id}', -1)" class="h-7 w-7 grid place-items-center rounded-md border border-slate-200 hover:bg-slate-100 text-slate-600 transition-colors">
              <i data-lucide="minus" class="h-3 w-3"></i>
            </button>
            <span class="w-7 text-center text-sm font-bold tabular-nums text-slate-800">${item.quantity}</span>
            <button onclick="updateQuantity('${item.id}', 1)" class="h-7 w-7 grid place-items-center rounded-md border border-slate-200 hover:bg-slate-100 text-slate-600 transition-colors">
              <i data-lucide="plus" class="h-3 w-3"></i>
            </button>
          </div>
          <button onclick="removeFromCart('${item.id}')" class="h-7 w-7 grid place-items-center rounded-md text-slate-400 hover:text-rose-600 hover:bg-rose-50 transition-colors">
            <i data-lucide="trash-2" class="h-3.5 w-3.5"></i>
          </button>
        `;
        cartList.appendChild(li);
      });
    }

    cartCount.innerText = `${totalItems} item(s)`;
    cartTotal.innerText = `R$ ${total.toFixed(2)}`;
    
    // Atualizar ícones do Lucide nos novos elementos gerados
    if (window.lucide) window.lucide.createIcons();
  }

  // Lógica do Modal de Pagamento
  function openPaymentModal() {
    if(cart.length === 0) return;
    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    document.getElementById('modal-total').innerText = `R$ ${total.toFixed(2)}`;
    document.getElementById('payment-modal').classList.remove('hidden');
    document.getElementById('payment-modal').classList.add('flex');
  }

  function closePaymentModal() {
    document.getElementById('payment-modal').classList.add('hidden');
    document.getElementById('payment-modal').classList.remove('flex');
  }

  // O "Motor" que envia o carrinho para o Back-end e gera o Recibo no WhatsApp
  async function processCheckout() {
    const btn = document.getElementById('btn-confirm-sale');
    const paymentMethod = document.getElementById('payment_method').value;
    const notes = document.getElementById('sale_notes').value;
    
    // Captura o WhatsApp e remove qualquer espaço ou traço que o utilizador possa ter digitado
    const rawWhatsapp = document.getElementById('customer_whatsapp').value;
    const whatsapp = rawWhatsapp.replace(/\D/g, ''); 

    btn.disabled = true;
    btn.innerHTML = `<i data-lucide="loader" class="h-5 w-5 animate-spin"></i> Processando...`;
    if (window.lucide) window.lucide.createIcons();

    try {
      // 1. Envia as vendas para o seu MongoDB
      const requests = cart.map(item => {
        const formData = new URLSearchParams();
        formData.append('product_id', item.id);
        formData.append('quantity', item.quantity);
        formData.append('payment_method', paymentMethod);
        formData.append('notes', notes);

        return fetch('/dashboard/sales/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: formData
        });
      });

      await Promise.all(requests);
      
      // 2. LÓGICA DO WHATSAPP: Se o cliente forneceu um número, cria a mensagem
      if (whatsapp && whatsapp.length >= 10) {
        const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
        
        // Monta o texto do recibo usando formatação do WhatsApp (asteriscos para negrito)
        let msg = `🧾 *COMPROVANTE DE COMPRA*\n_StoreHost PDV_\n\n`;
        msg += `*Itens adquiridos:*\n`;
        cart.forEach(item => {
          msg += `▪️ ${item.quantity}x ${item.name} (R$ ${(item.price * item.quantity).toFixed(2)})\n`;
        });
        msg += `\n💰 *Total Pago:* R$ ${total.toFixed(2)}`;
        msg += `\n💳 *Pagamento:* ${paymentMethod}`;
        if (notes) msg += `\n📝 *Notas:* ${notes}`;
        msg += `\n\n_Obrigado pela preferência! Volte sempre._ 🛍️`;
        
        // Converte o texto para formato de link (URL)
        const encodedMsg = encodeURIComponent(msg);
        const whatsappUrl = `https://api.whatsapp.com/send?phone=${whatsapp}&text=${encodedMsg}`;
        
        // Abre o WhatsApp numa nova aba
        window.open(whatsappUrl, '_blank');
      }

      // 3. Aguarda meio segundo e atualiza a tela do sistema para limpar o PDV
      setTimeout(() => {
          window.location.href = '/dashboard/sales?sucess=create';
      }, 500);

    } catch (error) {
      console.error("Erro ao finalizar a venda:", error);
      alert("Houve um erro ao processar a venda. Tente novamente.");
      btn.disabled = false;
      btn.innerHTML = `<i data-lucide="check-circle" class="h-5 w-5"></i> Confirmar Recebimento`;
      if (window.lucide) window.lucide.createIcons();
    }
  }
</script>