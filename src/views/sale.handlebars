<div class="content-body">
    <section class="welcome-sec">
        <h1>Ponto de Venda (PDV)</h1>
        <p>Registre as saídas de produtos e acompanhe o histórico de vendas recentes.</p>
    </section>
    
    <div class="main-grid">
        
        <section class="data-card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-3">
                <h2>Últimas Vendas</h2>
                
                <div style="flex: 1; max-width: 320px;">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted" style="border-radius: 10px 0 0 10px;">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control border-start-0 border-end-0 ps-0" placeholder="Pesquisar produto ou data..." style="font-size: 0.9rem; outline: none; box-shadow: none;">
                        <button class="btn btn-outline-secondary bg-white border-start-0 text-primary" type="button" id="btn-voz-pdv" title="Pesquisar por voz" style="border-radius: 0 10px 10px 0; border: 1px solid #dee2e6;">
                            <i class="bi bi-mic-fill" id="icone-microfone"></i>
                        </button>
                    </div>
                    <div id="status-voz" class="form-text text-danger d-none ps-2 pt-1" style="font-size: 0.8rem; font-weight: 500;">
                        <span class="spinner-grow spinner-grow-sm" role="status"></span> Ouvindo o operador...
                    </div>
                </div>
            </div>
            
            <div class="table-container mt-3">
                <table class="custom-table" id="salesTable">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Produto</th>
                            <th>Qtd.</th>
                            <th>Total</th>
                            <th>Pagamento</th>
                            <th>Status</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        {{#each vendas}}
                            <tr class="sale-row" data-search="{{this._id}} {{this.product_name}} {{formatDate this.createdAt}}">
                                <td><span style="font-size: 0.9rem; color: var(--text-main);">{{formatDate this.createdAt}}</span></td>
                                <td><strong>{{this.product_name}}</strong></td>
                                <td>{{this.quantity}}x</td>
                                <td><strong class="text-success">R$ {{this.total_price}}</strong></td>
                                <td><span class="badge bg-light text-dark border">{{this.payment_method}}</span></td>
                                <td><span class="badge-status status-active">Concluída</span></td>
                                <td>
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <!-- NOVO: Botão de WhatsApp para reenviar comprovante histórico se necessário -->
                                        <button class="btn btn-success btn-sm btn-wpp-share" 
                                            title="Enviar por WhatsApp"
                                            data-product="{{this.product_name}}"
                                            data-quantity="{{this.quantity}}"
                                            data-total="{{this.total_price}}"
                                            data-payment="{{this.payment_method}}">
                                            <i class="bi bi-whatsapp"></i>
                                        </button>

                                        <button class="btn btn-outline btn-sm" 
                                            title="Ajustar Venda"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editModal"
                                            data-id="{{this._id}}"
                                            data-product="{{this.product_id}}"
                                            data-quantity="{{this.quantity}}"
                                            data-payment="{{this.payment_method}}">
                                            Ajustar
                                        </button>

                                        <form action="/dashboard/sales/delete" method="POST" onsubmit="return confirm('Excluir esta venda irá devolver os itens ao estoque. Tem certeza?')" class="m-0">
                                            <input type="hidden" name="sale_id" value="{{this._id}}">
                                            <button type="submit" class="btn btn-danger btn-sm" title="Cancelar Venda">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {{else}}
                            <tr id="emptyRow">
                                <td colspan="7" style="text-align: center; padding: 2rem; color: var(--text-muted);">
                                    Nenhuma venda registrada ainda.
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>    
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3 p-2" id="paginationControls">
                <button class="btn btn-outline-secondary btn-sm" id="prevPage" disabled>
                    <i class="bi bi-chevron-left"></i> Anterior
                </button>
                <span id="pageIndicator" class="text-muted" style="font-size: 0.9rem;">Página 1</span>
                <button class="btn btn-outline-secondary btn-sm" id="nextPage">
                    Próxima <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </section>

        <section class="data-card">
            <div class="card-header">
                <h2>Nova Venda</h2>
            </div>
            <div id="alert-container"></div>

            <!-- MODIFICADO: Adicionado id para interceptação JavaScript -->
            <form action="/dashboard/sales/create" method="post" id="novaVendaForm">
                <div class="form-group mb-3">
                    <label>Produto</label>
                    <select name="product_id" id="form-select-product" class="form-input" required>
                        <option value="">Selecione um produto...</option>
                        {{#each produtos}}
                            <option value="{{this._id}}" data-name="{{this.name}}" data-price="{{this.price}}">
                                {{this.name}} - R$ {{this.price}} (Estoque: {{this.current_stock}} {{this.unit_of_measure}})
                            </option>
                        {{/each}}
                    </select>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 form-group">
                        <label>Quantidade</label>
                        <input type="number" name="quantity" id="form-input-quantity" min="0.001" step="0.001" class="form-input" required>
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Pagamento</label>
                        <select name="payment_method" id="form-select-payment" class="form-input" required>
                            <option value="Pix">Pix</option>
                            <option value="Cartão de Crédito">Cartão de Crédito</option>
                            <option value="Cartão de Débito">Cartão de Débito</option>
                            <option value="Dinheiro">Dinheiro</option>
                        </select>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 mt-2">
                    <i class="bi bi-cart-check"></i> Finalizar Venda
                </button>
            </form>
        </section>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editForm" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Ajustar Venda</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Produto</label>
                        <select name="product_id" id="edit-product" class="form-control" required>
                            {{#each produtos}}
                                <option value="{{this._id}}">{{this.name}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Quantidade</label>
                            <input type="number" name="quantity" id="edit-quantity" min="0.001" step="0.001" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Pagamento</label>
                            <select name="payment_method" id="edit-payment" class="form-control" required>
                                <option value="Pix">Pix</option>
                                <option value="Cartão de Crédito">Cartão de Crédito</option>
                                <option value="Cartão de Débito">Cartão de Débito</option>
                                <option value="Dinheiro">Dinheiro</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Salvar Ajuste</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    const alertContainer = document.getElementById('alert-container');

    if (urlParams.get('sucess') === 'create') {
        alertContainer.innerHTML = `
            <div class="alert alert-success d-flex align-items-center" role="alert">
            <svg width="20" height="20" fill="currentColor" class="bi flex-shrink-0 me-2" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <div style="font-size: 0.9rem;">Venda Registrada com Sucesso!</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
    } else if (urlParams.get('error') === 'quantity') {
        alertContainer.innerHTML = `
            <div class="alert alert-danger d-flex align-items-center alert-dismissible fade show" role="alert">
                <svg width="20" height="20" fill="currentColor" class="bi flex-shrink-0 me-2" viewBox="0 0 16 16">
                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
                <div style="font-size: 0.9rem;">Erro: A quantidade vendida é maior que o estoque atual.</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
    }

    const editModal = document.getElementById('editModal');
    if (editModal) {
        editModal.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            
            const id = button.getAttribute('data-id');
            const productId = button.getAttribute('data-product');
            const quantity = button.getAttribute('data-quantity');
            const payment = button.getAttribute('data-payment');

            editModal.querySelector('#edit-product').value = productId;
            editModal.querySelector('#edit-quantity').value = quantity;
            editModal.querySelector('#edit-payment').value = payment;
            
            editModal.querySelector('#editForm').action = `/dashboard/sales/update/${id}`;
        });
    }

    document.addEventListener("DOMContentLoaded", function() {
        const searchInput = document.getElementById("searchInput");
        const allRows = Array.from(document.querySelectorAll(".sale-row")); 
        let filteredRows = [...allRows]; 
        
        let currentPage = 1;
        const rowsPerPage = 10; 

        const btnPrev = document.getElementById("prevPage");
        const btnNext = document.getElementById("nextPage");
        const pageIndicator = document.getElementById("pageIndicator");

        const btnVoz = document.getElementById("btn-voz-pdv");
        const statusVoz = document.getElementById("status-voz");
        const iconeMic = document.getElementById("icone-microfone");

        function renderTable() {
            allRows.forEach(row => row.style.display = "none");
            
            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;

            const rowsToShow = filteredRows.slice(startIndex, endIndex);
            rowsToShow.forEach(row => row.style.display = ""); 

            const totalPages = Math.ceil(filteredRows.length / rowsPerPage) || 1;
            pageIndicator.textContent = `Página ${currentPage} de ${totalPages}`;
            
            btnPrev.disabled = currentPage === 1;
            btnNext.disabled = currentPage === totalPages;
        }

        function executarFiltro(termo) {
            const searchTerm = termo.toLowerCase().trim();
            
            filteredRows = allRows.filter(row => {
                const searchData = row.getAttribute("data-search").toLowerCase();
                return searchData.includes(searchTerm);
            });
            
            currentPage = 1;
            renderTable();
        }

        if(searchInput) {
            searchInput.addEventListener("input", function(e) {
                executarFiltro(e.target.value);
            });
        }

        // 🎙️ WEB SPEECH API
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (SpeechRecognition) {
            const recognition = new SpeechRecognition();
            recognition.lang = "pt-BR";
            recognition.continuous = false;
            recognition.interimResults = false;

            if (btnVoz) {
                btnVoz.addEventListener("click", () => {
                    try { recognition.start(); } catch (err) { console.warn("Reconhecimento já ativo."); }
                });
            }

            recognition.onstart = () => {
                statusVoz.classList.remove("d-none");
                iconeMic.className = "bi bi-record-circle-fill text-danger";
                btnVoz.style.borderColor = "#dc3545";
            };

            recognition.onend = () => {
                statusVoz.classList.add("d-none");
                iconeMic.className = "bi bi-mic-fill text-primary";
                btnVoz.style.borderColor = "#dee2e6";
            };

            recognition.onresult = (event) => {
                const textoFalado = event.results[0][0].transcript;
                const textoLimpo = textoFalado.replace(/\.$/g, ''); 
                searchInput.value = textoLimpo;
                executarFiltro(textoLimpo); 
            };
        }

        // ==========================================
// 🚀 LÓGICA DO WHATSAPP (VERSÃO COM SÍMBOLOS UNIVERSAIS)
// ==========================================

function dispararWhatsApp(telefone, dados) {
    // Remove caracteres não numéricos do telefone
    const numLimpo = telefone.replace(/\D/g, "");
    const DDI = numLimpo.length <= 11 ? "55" : ""; // Adiciona DDI Brasil se o lojista não digitar
    
    // Símbolos de texto geométricos universais (Zero bugs de codificação)
    const simboLoja      = "[+]";
    const simboProduto   = "->";
    const simboQtd       = "#";
    const simboPagamento = "($)";
    const simboTotal     = "[R$]";
    const simboSucesso   = "(*)";

    const mensagem = simboLoja + " *COMPROVANTE DE COMPRA* \n\n" +
                     simboProduto + " *Produto:* " + dados.produto + "\n" +
                     simboQtd + " *Quantidade:* " + dados.quantidade + "\n" +
                     simboPagamento + " *Forma de Pagamento:* " + dados.pagamento + "\n" +
                     simboTotal + " *Valor Total:* R$ " + dados.total + "\n\n" +
                     "Obrigado pela preferência! Volte sempre. " + simboSucesso;

    // Concatenação limpa e segura para a URL do WhatsApp
    const urlWpp = "https://wa.me/" + DDI + numLimpo + "?text=" + encodeURIComponent(mensagem);
    window.open(urlWpp, "_blank");
}


        // Fluxo 1: Captura o clique de envio nas linhas da tabela (Histórico)
        document.querySelectorAll(".btn-wpp-share").forEach(botao => {
            botao.addEventListener("click", function() {
                const dadosVenda = {
                    produto: this.getAttribute("data-product"),
                    quantidade: this.getAttribute("data-quantity"),
                    total: this.getAttribute("data-total"),
                    pagamento: this.getAttribute("data-payment")
                };

                const telefoneCliente = prompt("Digite o WhatsApp do cliente com o DDD (Ex: 71999999999):");
                if (telefoneCliente) {
                    dispararWhatsApp(telefoneCliente, dadosVenda);
                }
            });
        });

        // Fluxo 2: Intercepta o formulário de NOVA VENDA para disparar o WhatsApp ANTES de salvar
        const formNovaVenda = document.getElementById("novaVendaForm");
        if (formNovaVenda) {
            formNovaVenda.addEventListener("submit", function(e) {
                // Previne temporariamente para processarmos o alert/prompt do número
                e.preventDefault();

                const selectProduto = document.getElementById("form-select-product");
                const opcaoSelecionada = selectProduto.options[selectProduto.selectedIndex];
                
                const produtoNome = opcaoSelecionada.getAttribute("data-name");
                const produtoPreco = parseFloat(opcaoSelecionada.getAttribute("data-price"));
                const qtd = parseFloat(document.getElementById("form-input-quantity").value);
                const pagamento = document.getElementById("form-select-payment").value;
                const totalCalculado = (produtoPreco * qtd).toFixed(2);

                const telefoneCliente = prompt("Venda confirmada! Deseja enviar o recibo por WhatsApp?\n\nDigite o número com o DDD ou clique em 'Cancelar' para salvar sem enviar:");
                
                if (telefoneCliente && telefoneCliente.trim() !== "") {
                    dispararWhatsApp(telefoneCliente, {
                        produto: produtoNome,
                        quantidade: qtd,
                        total: totalCalculado,
                        pagamento: pagamento
                    });
                }

                // Após processar o fluxo do WhatsApp, envia o formulário de verdade para persistir no MongoDB
                formNovaVenda.submit();
            });
        }

        if(btnPrev) {
            btnPrev.addEventListener("click", () => {
                if (currentPage > 1) { currentPage--; renderTable(); }
            });
        }

        if(btnNext) {
            btnNext.addEventListener("click", () => {
                const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
                if (currentPage < totalPages) { currentPage++; renderTable(); }
            });
        }

        renderTable();
    });
</script>