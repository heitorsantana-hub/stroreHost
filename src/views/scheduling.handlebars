<div class="space-y-6 p-4 sm:p-6 max-w-[1600px] mx-auto">
  
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Agenda Operacional</h1>
      <p class="mt-1 text-sm text-slate-500 max-w-2xl">
        Faça a gestão dos compromissos da loja e acompanhe o estado de cada serviço.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <button onclick="openModal('createModal')" class="h-9 px-4 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-indigo-500 shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all inline-flex items-center gap-2">
        <i data-lucide="plus" class="h-4 w-4"></i> Novo Agendamento
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 shadow-sm flex items-center gap-4 transition hover:shadow-md">
      <div class="h-12 w-12 rounded-full bg-amber-200/50 text-amber-600 grid place-items-center shrink-0">
        <i data-lucide="clock" class="h-6 w-6"></i>
      </div>
      <div>
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-amber-600/80">A Aguardar</div>
        <div class="text-2xl font-bold text-amber-900" id="count-pendentes">0</div>
      </div>
    </div>
    
    <div class="rounded-2xl border border-blue-200 bg-blue-50 p-5 shadow-sm flex items-center gap-4 transition hover:shadow-md">
      <div class="h-12 w-12 rounded-full bg-blue-200/50 text-blue-600 grid place-items-center shrink-0">
        <i data-lucide="calendar-check" class="h-6 w-6"></i>
      </div>
      <div>
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-blue-600/80">Confirmados</div>
        <div class="text-2xl font-bold text-blue-900" id="count-confirmados">0</div>
      </div>
    </div>

    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 shadow-sm flex items-center gap-4 transition hover:shadow-md">
      <div class="h-12 w-12 rounded-full bg-emerald-200/50 text-emerald-600 grid place-items-center shrink-0">
        <i data-lucide="check-circle-2" class="h-6 w-6"></i>
      </div>
      <div>
        <div class="text-xs font-bold uppercase tracking-[0.25em] text-emerald-600/80">Concluídos</div>
        <div class="text-2xl font-bold text-emerald-900" id="count-concluidos">0</div>
      </div>
    </div>
  </div>
  
  <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    
    <div class="p-5 border-b border-slate-200 flex flex-wrap items-center justify-between gap-4 bg-slate-50/50">
      <h2 class="text-base font-bold text-slate-900 flex items-center gap-2">
        <i data-lucide="list-todo" class="h-5 w-5 text-indigo-600"></i>
        Lista de Compromissos
      </h2>
      
      <div class="flex items-center gap-1 bg-slate-100 p-1 rounded-lg border border-slate-200" id="filter-buttons">
        <button data-filter="all" class="px-3 py-1.5 text-xs font-bold rounded-md bg-white shadow-sm text-slate-800 transition-all">Todos</button>
        <button data-filter="Pendente" class="px-3 py-1.5 text-xs font-bold rounded-md text-slate-500 hover:text-slate-700 transition-all">Pendentes</button>
        <button data-filter="Confirmado" class="px-3 py-1.5 text-xs font-bold rounded-md text-slate-500 hover:text-slate-700 transition-all">Confirmados</button>
      </div>
    </div>
    
    <div class="p-5 space-y-4 calendar-events-list">
      {{#if schedules}}
        {{#each schedules}}
          <div class="schedule-card flex flex-col sm:flex-row justify-between items-start sm:items-center p-4 rounded-xl border border-slate-200 bg-white shadow-sm hover:border-indigo-300 hover:shadow-md transition-all gap-4" data-status="{{this.status}}">
            
            <div class="flex items-center gap-4 flex-1">
              <div class="flex flex-col items-center justify-center min-w-[90px] pr-4 border-r border-slate-100">
                <span class="text-xl font-black text-slate-800 tracking-tight">{{this.scheduled_time}}</span>
                <span class="text-xs font-bold text-slate-400 mt-0.5">{{formatDate this.scheduled_date}}</span>
              </div>
              
              <div>
                <h4 class="font-bold text-slate-900 text-base mb-1">{{this.service_type}}</h4>
                <div class="text-sm font-medium text-slate-600 flex flex-wrap items-center gap-x-4 gap-y-1">
                  <span class="flex items-center gap-1.5"><i data-lucide="user" class="h-3.5 w-3.5 text-slate-400"></i> {{this.customer_name}}</span>
                  <span class="flex items-center gap-1.5"><i data-lucide="phone" class="h-3.5 w-3.5 text-slate-400"></i> {{this.customer_phone}}</span>
                </div>
                <div class="text-xs font-medium text-indigo-600 mt-2 flex items-center gap-1.5">
                  <i data-lucide="briefcase" class="h-3 w-3"></i> Profissional: {{this.employee_name}}
                </div>
              </div>
            </div>
            
            <div class="flex sm:flex-col items-center sm:items-end justify-between w-full sm:w-auto gap-3">
              
              {{#if (eq this.status 'Pendente')}}
                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-100 text-amber-700 border border-amber-200">Pendente</span>
              {{else if (eq this.status 'Confirmado')}}
                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-700 border border-blue-200">Confirmado</span>
              {{else if (eq this.status 'Concluído')}}
                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-100 text-emerald-700 border border-emerald-200">Concluído</span>
              {{else}}
                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-rose-100 text-rose-700 border border-rose-200">Cancelado</span>
              {{/if}}

              <div class="flex items-center gap-2">
                <button 
                  onclick="openEditModal(this)"
                  data-id="{{this._id}}"
                  data-date="{{this.scheduled_date}}"
                  data-time="{{this.scheduled_time}}"
                  data-customer-name="{{this.customer_name}}"
                  data-customer-phone="{{this.customer_phone}}"
                  data-service-type="{{this.service_type}}"
                  data-status="{{this.status}}"
                  data-notes="{{this.notes}}"
                  class="h-8 w-8 grid place-items-center rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-500 hover:text-indigo-600 transition-colors" title="Editar">
                  <i data-lucide="pencil" class="h-4 w-4"></i>
                </button>

                <form action="/dashboard/scheduling/delete" method="POST" class="m-0" onsubmit="return confirm('Tem certeza que deseja apagar este agendamento?');">
                  <input type="hidden" name="schedule_id" value="{{this._id}}">
                  <button type="submit" class="h-8 w-8 grid place-items-center rounded-lg border border-slate-200 bg-white hover:bg-rose-50 text-slate-500 hover:text-rose-600 transition-colors" title="Apagar">
                    <i data-lucide="trash-2" class="h-4 w-4"></i>
                  </button>
                </form>
              </div>

            </div>
          </div>
        {{/each}}
      {{else}}
        <div class="py-12 text-center text-slate-400 flex flex-col items-center justify-center">
          <i data-lucide="calendar-x-2" class="h-12 w-12 mb-3 opacity-50"></i>
          <h5 class="text-base font-bold text-slate-600">Agenda Livre</h5>
          <p class="text-sm mt-1">Nenhum compromisso registado. Clique em "Novo Agendamento" para começar.</p>
        </div>
      {{/if}}
    </div>
  </div>
</div>

<div id="createModal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-2xl items-center justify-center w-full">
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
        <h5 class="font-bold text-slate-900 flex items-center gap-2">
          <i data-lucide="calendar-plus" class="h-5 w-5 text-indigo-600"></i> Novo Agendamento
        </h5>
        <button type="button" onclick="closeModal('createModal')" class="text-slate-400 hover:text-slate-600">
          <i data-lucide="x" class="h-5 w-5"></i>
        </button>
      </div>
      
      <form action="/dashboard/scheduling/create" method="POST" class="p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          
          <div class="sm:col-span-2">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Funcionário</label>
            <select name="employee_id" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-colors">
              <option value="">Selecione um profissional</option>
              {{#each employees}}
                <option value="{{this._id}}">{{this.name}}</option>
              {{/each}}
            </select>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Data</label>
            <input type="date" name="scheduled_date" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Horário</label>
            <input type="time" name="scheduled_time" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div class="sm:col-span-2">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Tipo de Serviço</label>
            <input type="text" name="service_type" placeholder="Ex: Corte, Manutenção..." required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Nome do Cliente</label>
            <input type="text" name="customer_name" placeholder="Nome completo" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Telefone</label>
            <input type="tel" name="customer_phone" placeholder="(00) 00000-0000" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div class="sm:col-span-2">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Observações (Opcional)</label>
            <textarea name="notes" placeholder="Detalhes importantes sobre o serviço" rows="2" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500"></textarea>
          </div>

        </div>
        
        <div class="flex justify-end gap-2 mt-6 pt-4 border-t border-slate-100">
          <button type="button" onclick="closeModal('createModal')" class="px-4 py-2 text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-colors">Cancelar</button>
          <button type="submit" class="px-6 py-2 text-sm font-bold bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl shadow-md transition-colors flex items-center gap-2">
            <i data-lucide="save" class="h-4 w-4"></i> Salvar Agendamento
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="editModal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-2xl items-center justify-center w-full">
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
        <h5 class="font-bold text-slate-900 flex items-center gap-2">
          <i data-lucide="edit-3" class="h-5 w-5 text-indigo-600"></i> Atualizar Agendamento
        </h5>
        <button type="button" onclick="closeModal('editModal')" class="text-slate-400 hover:text-slate-600">
          <i data-lucide="x" class="h-5 w-5"></i>
        </button>
      </div>
      
      <form id="editForm" action="/dashboard/scheduling/update/0" method="POST" class="p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Data</label>
            <input type="date" id="editDate" name="scheduled_date" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Horário</label>
            <input type="time" id="editTime" name="scheduled_time" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div class="sm:col-span-2">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Serviço</label>
            <input type="text" id="editServiceType" name="service_type" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Cliente</label>
            <input type="text" id="editCustomerName" name="customer_name" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Telefone</label>
            <input type="tel" id="editCustomerPhone" name="customer_phone" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500">
          </div>

          <div class="sm:col-span-2">
            <label class="block text-xs font-bold text-indigo-600 uppercase tracking-wider mb-1.5">Estado do Serviço</label>
            <select id="editStatus" name="status" class="w-full px-3 py-2 border border-indigo-300 rounded-xl text-sm bg-indigo-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 font-bold text-indigo-900 transition-colors">
              <option value="Pendente">Pendente</option>
              <option value="Confirmado">Confirmado</option>
              <option value="Concluído">Concluído</option>
              <option value="Cancelado">Cancelado</option>
            </select>
          </div>

        </div>
        
        <div class="flex justify-end gap-2 mt-6 pt-4 border-t border-slate-100">
          <button type="button" onclick="closeModal('editModal')" class="px-4 py-2 text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-colors">Cancelar</button>
          <button type="submit" class="px-6 py-2 text-sm font-bold bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl shadow-md transition-colors">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Renderiza os ícones
    if (window.lucide) window.lucide.createIcons();

    // 2. Lógica de Contagem de KPIs e Filtros
    const cards = document.querySelectorAll('.schedule-card');
    let countPendentes = 0, countConfirmados = 0, countConcluidos = 0;
    
    cards.forEach(card => {
      const status = card.getAttribute('data-status');
      if(status === 'Pendente') countPendentes++;
      if(status === 'Confirmado') countConfirmados++;
      if(status === 'Concluído') countConcluidos++;
    });

    // Atualiza os números no topo do ecrã
    if(document.getElementById('count-pendentes')) document.getElementById('count-pendentes').innerText = countPendentes;
    if(document.getElementById('count-confirmados')) document.getElementById('count-confirmados').innerText = countConfirmados;
    if(document.getElementById('count-concluidos')) document.getElementById('count-concluidos').innerText = countConcluidos;

    // Lógica dos Botões de Filtro
    const filterButtons = document.querySelectorAll('#filter-buttons button');
    
    filterButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        // Remove a classe 'active' style de todos
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-white', 'shadow-sm', 'text-slate-800');
          btn.classList.add('text-slate-500');
        });
        
        // Adiciona classe ativa no botão clicado
        e.target.classList.remove('text-slate-500');
        e.target.classList.add('bg-white', 'shadow-sm', 'text-slate-800');

        const filterValue = e.target.getAttribute('data-filter');

        // Esconde ou mostra os cartões
        cards.forEach(card => {
          if(filterValue === 'all') {
            card.style.display = 'flex';
          } else {
            if(card.getAttribute('data-status') === filterValue) {
              card.style.display = 'flex';
            } else {
              card.style.display = 'none';
            }
          }
        });
      });
    });
  });

  // 3. Controle dos Modais nativo
  function openModal(id) {
    const modal = document.getElementById(id);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal(id) {
    const modal = document.getElementById(id);
    modal.classList.remove('flex');
    modal.classList.add('hidden');
  }

  // Abre o modal de edição injetando os dados do botão clicado
  function openEditModal(btn) {
    document.getElementById('editForm').action = `/dashboard/scheduling/update/${btn.dataset.id}`;
    
    // Tratamento de data para o input type="date"
    const rawDate = btn.dataset.date;
    if(rawDate) {
       document.getElementById('editDate').value = new Date(rawDate).toISOString().split('T')[0];
    } else {
       document.getElementById('editDate').value = '';
    }

    document.getElementById('editTime').value = btn.dataset.time;
    document.getElementById('editCustomerName').value = btn.dataset.customerName;
    document.getElementById('editCustomerPhone').value = btn.dataset.customerPhone;
    document.getElementById('editServiceType').value = btn.dataset.serviceType;
    document.getElementById('editStatus').value = btn.dataset.status;
    
    openModal('editModal');
  }
</script>