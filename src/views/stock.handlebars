<div class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Controlo de Estoque</h1>
      <p class="mt-1 text-sm text-slate-500 max-w-2xl">
        Monitore níveis, receba alertas de reposição e evite capital travado.
      </p>
    </div>
    <button onclick="openModal('stock-movement-modal')" class="h-9 px-4 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-indigo-500 shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all flex items-center gap-2">
      <i data-lucide="arrow-right-left" class="h-4 w-4"></i>
      Movimentar Estoque
    </button>
  </div>

  <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Total em estoque</div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">{{total_estoque}}</div>
      <div class="mt-1 text-xs font-bold text-slate-500">Unidades físicas na loja</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Itens críticos</div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">{{itens_criticos}}</div>
      <div class="mt-1 text-xs font-bold text-rose-600">Requerem reposição urgente</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Giro médio</div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">{{giro_medio}}</div>
      <div class="mt-1 text-xs font-bold text-emerald-600">Estabilidade de saída</div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Valor imobilizado</div>
      <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">R$ {{valor_imobilizado}}</div>
      <div class="mt-1 text-xs font-bold text-slate-500">Capital investido nos produtos</div>
    </div>
  </section>

  <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    <div class="p-4 border-b border-slate-200 flex items-center justify-between bg-slate-50/50">
      <h2 class="text-base font-bold text-slate-900">Níveis por produto</h2>
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white h-9 px-3 focus-within:border-indigo-500 transition-colors">
          <i data-lucide="search" class="h-4 w-4 text-slate-400"></i>
          <input id="search-stock" onkeyup="filterStock()" placeholder="Pesquisar..." class="w-32 sm:w-48 bg-transparent outline-none text-sm text-slate-900 placeholder:text-slate-400" />
        </div>
      </div>
    </div>

    <div class="divide-y divide-slate-200 max-h-[600px] overflow-y-auto" id="stock-list">
      
      {{#each produtos}}
      <div class="p-4 grid grid-cols-12 gap-3 items-center hover:bg-slate-50/60 transition-colors stock-row"
           data-name="{{this.name}}" 
           data-current="{{this.current_stock}}" 
           data-min="{{this.min_stock}}" 
           data-max="{{this.max_stock}}">
        
        <div class="col-span-12 sm:col-span-4 flex items-center gap-3">
          <div class="h-8 w-8 rounded bg-slate-100 flex items-center justify-center border border-slate-200 shrink-0">
             {{#if this.image_url}}
                <img src="{{this.image_url}}" class="h-full w-full object-cover rounded" onerror="this.style.display='none'">
             {{else}}
                <i data-lucide="package" class="h-4 w-4 text-slate-400"></i>
             {{/if}}
          </div>
          <span class="font-bold text-slate-800 truncate" title="{{this.name}}">{{this.name}}</span>
        </div>
        
        <div class="col-span-12 sm:col-span-5">
          <div class="relative h-2 rounded-full bg-slate-100 overflow-hidden">
            <div class="absolute inset-y-0 left-0 rounded-full progress-bar transition-all duration-700 ease-out" style="width: 0%"></div>
          </div>
          <div class="mt-1 flex justify-between text-[11px] font-medium text-slate-400">
            <span>mín {{this.min_stock}}</span>
            <span>máx {{this.max_stock}}</span>
          </div>
        </div>
        
        <div class="col-span-6 sm:col-span-2 text-sm tabular-nums font-bold text-slate-900 text-center">
          {{this.current_stock}} <span class="text-xs font-normal text-slate-500">{{this.unit_of_measure}}</span>
        </div>
        
        <div class="col-span-6 sm:col-span-1 text-right">
          <span class="status-badge inline-flex rounded-full px-2.5 py-0.5 text-[11px] font-bold border"></span>
        </div>
      </div>
      {{else}}
      <div class="p-12 text-center text-slate-400">
        <i data-lucide="inbox" class="h-12 w-12 mx-auto mb-3 opacity-50"></i>
        <p>Não há produtos no catálogo para exibir o nível de stock.</p>
      </div>
      {{/each}}
      
    </div>
  </div>
</div>

<div id="stock-movement-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm p-4 sm:p-6" style="z-index: 9999;">
  <div class="mx-auto flex min-h-full max-w-md items-center justify-center">
    <div class="w-full rounded-2xl border border-slate-200 bg-white shadow-2xl overflow-hidden">
      <div class="p-6 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
        <div>
          <h3 class="text-lg font-bold text-slate-900">Movimentar Estoque</h3>
          <p class="text-xs text-slate-500">Registe uma entrada ou saída manual.</p>
        </div>
        <button type="button" onclick="closeModal('stock-movement-modal')" class="text-slate-400 hover:text-slate-600 h-8 w-8 flex items-center justify-center rounded-lg hover:bg-slate-200 transition-colors">
          <i data-lucide="x" class="h-5 w-5"></i>
        </button>
      </div>
      
      <form action="/dashboard/stock/update" method="POST" class="p-6 space-y-4">
        
        <div>
          <label class="mb-1 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Produto</label>
          <select name="product_id" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors">
            <option value="">Selecione um produto...</option>
            {{#each produtos}}
              <option value="{{this._id}}">{{this.name}} (Atual: {{this.current_stock}})</option>
            {{/each}}
          </select>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Tipo de Movimento</label>
            <select name="type" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm font-bold text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors">
              <option value="in" class="text-emerald-600">Entrada (+)</option>
              <option value="out" class="text-rose-600">Saída (-)</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Quantidade</label>
            <input name="quantity" type="number" step="0.001" min="0.001" required placeholder="Ex: 10" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white">
          </div>
        </div>

        <div>
          <label class="mb-1 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Motivo</label>
          <select name="reason" required class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white transition-colors">
            <option value="compra">Nova Compra de Fornecedor</option>
            <option value="ajuste">Ajuste / Contagem de Inventário</option>
            <option value="devolucao">Devolução de Cliente</option>
            <option value="perda_validade">Perda / Validade Expirada</option>
          </select>
        </div>

        <div>
          <label class="mb-1 block text-xs font-bold uppercase tracking-[0.2em] text-slate-700">Valor Unitário Opcional (R$)</label>
          <input name="unit_value" type="number" step="0.01" placeholder="Custo por unidade nesta transação" class="h-10 w-full rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm text-slate-800 outline-none focus:border-indigo-500 focus:bg-white">
          <p class="text-[10px] text-slate-500 mt-1">Deixe em branco para usar o preço de custo padrão do produto.</p>
        </div>

        <div class="pt-4 border-t border-slate-100">
          <button type="submit" class="w-full h-11 rounded-lg text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-indigo-500 shadow-md shadow-indigo-600/10 hover:from-indigo-500 hover:to-indigo-600 transition-all flex items-center justify-center gap-2">
            <i data-lucide="check" class="h-4 w-4"></i> Confirmar Registo
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Injeta os ícones
    if (window.lucide) window.lucide.createIcons();

    // 2. Motor de Níveis de Stock (Barras de Progresso Mágicas)
    const rows = document.querySelectorAll('.stock-row');
    
    rows.forEach(row => {
      // Lê os atributos data-*
      const current = parseFloat(row.getAttribute('data-current')) || 0;
      const min = parseFloat(row.getAttribute('data-min')) || 0;
      const max = parseFloat(row.getAttribute('data-max')) || 1; // Previne divisão por zero
      
      const bar = row.querySelector('.progress-bar');
      const badge = row.querySelector('.status-badge');
      
      // Calcula a percentagem para a largura da barra
      let pct = (current / max) * 100;
      if (pct > 100) pct = 100;
      
      // Anima a barra
      setTimeout(() => { bar.style.width = pct + '%'; }, 150);

      // Lógica de Inteligência de Cores e Estados
      if (current <= 0) {
        bar.classList.add('bg-rose-600');
        badge.classList.add('bg-rose-50', 'border-rose-200', 'text-rose-700');
        badge.innerText = 'Esgotado';
      } 
      else if (current <= min) {
        bar.classList.add('bg-amber-500');
        badge.classList.add('bg-amber-50', 'border-amber-200', 'text-amber-700');
        badge.innerText = 'Crítico';
      } 
      else if (current > max) {
        bar.classList.add('bg-indigo-400');
        badge.classList.add('bg-indigo-50', 'border-indigo-200', 'text-indigo-700');
        badge.innerText = 'Excesso';
      } 
      else {
        bar.classList.add('bg-emerald-500');
        badge.classList.add('bg-emerald-50', 'border-emerald-200', 'text-emerald-700');
        badge.innerText = 'Estável';
      }
    });
  });

  // 3. Sistema de Pesquisa Rápida na Lista
  function filterStock() {
    const input = document.getElementById('search-stock').value.toLowerCase();
    const rows = document.querySelectorAll('.stock-row');
    
    rows.forEach(row => {
      const name = row.getAttribute('data-name').toLowerCase();
      row.style.display = name.includes(input) ? '' : 'none';
    });
  }

  // 4. Controlo do Modal
  function openModal(id) {
    const modal = document.getElementById(id);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal(id) {
    const modal = document.getElementById(id);
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
</script>