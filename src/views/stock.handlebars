
    <div class="content-body">
        
        <section class="welcome-sec">
            <h1>Controle de Estoque</h1>
            <p>Monitore os níveis de produtos e registre entradas ou saídas.</p>
        </section>

        <div class="main-grid">
            
    <section class="data-card">
    <div class="card-header">
        <h2>Níveis de Estoque</h2>
    </div>
    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Produto</th>
                    <th>Qtd. Atual</th>
                    <th>Valor</th>
                    <th>Última Mov.</th>
                    <th>Ações</th> </tr>
            </thead>
            <tbody>
                {{#each produtos}}
                    <tr>
                        <td><strong>{{this.name}}</strong></td>
                        
                        <td>{{this.current_stock}} un.</td> 
                        
                        <td>R$ {{this.price}}</td>
                        
                        <td style="color: var(--text-muted); font-size: 0.85rem;">Sem registro</td>
                        
                       <td>
                         <button 
                        class="btn btn-outline" 
                        data-bs-toggle="modal" 
                        data-bs-target="#editModal"
                        data-id="{{this._id}}"
                        data-quantity="{{this.current_stock}}">
                        Editar
                    </button>
                       </td>
                        
                    </tr>
                {{else}}
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-muted);">
                            Nenhum produto cadastrado ainda. Use o formulário ao lado para começar!
                        </td>
                    </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</section>

            <section class="data-card">
                <div class="card-header">
                    <h2>Movimentar Estoque</h2>
                </div>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">Adicione entradas ou saídas de itens.</p>

                <div id="alert-container"></div>
                
                <form action="/dashboard/stock/update" method="post">
                    <div class="form-group">
                        <label>Selecionar Produto</label>
                        <select name="product_id" class="form-input" required>
                            <option value="">Escolha um produto...</option>
                            {{#each produtos}}
                                <option value="{{this._id}}">{{this.name}}</option>
                            {{/each}}

                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantidade</label>
                        <input type="number" name="quantity" class="form-input" min="1" required>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Atualizar Estoque</button>
                </form>
            </section>

        </div>
    </div>

    <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editStockForm" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Colaborador</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label>Quantidade</label>
                        <input type="text" name="quantity" id="edit-quantity" class="form-input" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('sucess') === 'create') {
            const alertContainer = document.getElementById('alert-container');
            alertContainer.innerHTML = `
                <div class="alert alert-success d-flex align-items-center" role="alert">
                <svg width="20" height="20" fill="currentColor" class="bi flex-shrink-0 me-2" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                    <div style="font-size: 0.9rem;">Quantidade Registrada com Sucesso!</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
        }

        const editModal = document.getElementById('editModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', event => {
                const btn = event.relatedTarget; // O botão que foi clicado
                
                // Pegando os dados da "mochila" do botão
                const id = btn.getAttribute('data-id');
                const quantity = btn.getAttribute('data-quantity');

                // Preenchendo o input de quantidade
                editModal.querySelector('#edit-quantity').value = quantity;
                
                // IMPORTANTE: O ID do form aqui deve ser igual ao do HTML (#editStockForm)
                const form = editModal.querySelector('#editStockForm');
                form.action = `/dashboard/stock/update/${id}`;
            });
        }
    </script>